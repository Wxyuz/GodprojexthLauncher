$ErrorActionPreference = "Stop"
$ProgressPreference = "SilentlyContinue"
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

$RepoOwner = "Wxyuz"
$RepoName = "GodprojexthLauncher"

$PreferredZipName = "GODPROJEXTH_PORTABLE.zip"
$PreferredExeName = "POWERSHELLGODPROJEXTH.exe"

$PossibleZipNames = @(
    "GODPROJEXTH_PORTABLE.zip",
    "POWERSHELLGODPROJEXTH.zip",
    "GODPROJEXTH.zip",
    "GODPROJEXTH_ALPHA.zip",
    "ALPHA_GODPROJEXTH.zip"
)

$PossibleExeNames = @(
    "POWERSHELLGODPROJEXTH.exe",
    "GODPROJEXTH.exe",
    "GODPROJEXTH_ALPHA.exe",
    "ALPHA_GODPROJEXTH.exe",
    "GODPROJEXTHALPHA.exe",
    "Powershell.exe",
    "_Flix.exe"
)

$InstallDir = Join-Path $env:LOCALAPPDATA "GodprojexthPremium"
$PackageDir = Join-Path $InstallDir "package"
$RuntimeTempDir = Join-Path $InstallDir "runtime_tmp"
$ZipPath = Join-Path $InstallDir $PreferredZipName
$TempZipPath = Join-Path $InstallDir ($PreferredZipName + ".download")
$FallbackExePath = Join-Path $InstallDir $PreferredExeName
$TempExePath = Join-Path $InstallDir ($PreferredExeName + ".download")

$ExpectedZipSha256 = ""
$ExpectedExeSha256 = ""

$AlwaysDownloadLatest = $true
$DownloadRetryCount = 3

function Initialize-Console {
    try {
        [Console]::OutputEncoding = [System.Text.Encoding]::UTF8
        [Console]::InputEncoding = [System.Text.Encoding]::UTF8
        [Console]::CursorVisible = $false
        $Host.UI.RawUI.WindowTitle = "GODPROJEXTH PREMIUM RUNNER"
    }
    catch {
    }

    try {
        $max = $Host.UI.RawUI.MaxPhysicalWindowSize
        $buffer = $Host.UI.RawUI.BufferSize
        $window = $Host.UI.RawUI.WindowSize

        $targetWidth = [Math]::Min(108, $max.Width)
        $targetHeight = [Math]::Min(32, $max.Height)

        if ($buffer.Width -lt $targetWidth) {
            $Host.UI.RawUI.BufferSize = New-Object System.Management.Automation.Host.Size($targetWidth, [Math]::Max($buffer.Height, 1000))
        }

        if ($window.Width -lt 96) {
            $Host.UI.RawUI.WindowSize = New-Object System.Management.Automation.Host.Size($targetWidth, $targetHeight)
        }
    }
    catch {
    }

    Clear-Host
}

function Get-ConsoleWidthSafe {
    try {
        return [Math]::Max(80, $Host.UI.RawUI.WindowSize.Width)
    }
    catch {
        return 100
    }
}

function Write-Typed {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::Yellow,
        [int]$Delay = 1,
        [switch]$NoNewLine
    )

    foreach ($char in $Text.ToCharArray()) {
        Write-Host $char -NoNewline -ForegroundColor $Color

        if ($Delay -gt 0) {
            Start-Sleep -Milliseconds $Delay
        }
    }

    if (-not $NoNewLine) {
        Write-Host ""
    }
}

function Write-Centered {
    param(
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::Yellow,
        [int]$Delay = 0
    )

    $width = Get-ConsoleWidthSafe
    $left = [Math]::Max(0, [Math]::Floor(($width - $Text.Length) / 2))
    $line = (" " * $left) + $Text

    if ($Delay -le 0) {
        Write-Host $line -ForegroundColor $Color
    }
    else {
        Write-Typed $line $Color $Delay
    }
}

function Write-Status {
    param(
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::Green,
        [int]$Delay = 1
    )

    Write-Host "   " -NoNewline
    Write-Typed "[GODPROJEXTH] $Text" $Color $Delay
}

function Show-Header {
    Clear-Host
    Write-Host ""
    Write-Centered "╔══════════════════════════════════════════════════════════════════════╗" DarkYellow
    Write-Centered "║                                                                      ║" DarkYellow
    Write-Centered "║                         G O D P R O J E X T H                        ║" Yellow
    Write-Centered "║                                                                      ║" DarkYellow
    Write-Centered "║      █▀▀ █▀█ █▀▄ █▀█ █▀█ █▀█ ░░█ █▀▀ ▀▄▀ ▀█▀ █░█                    ║" Yellow
    Write-Centered "║      █▄█ █▄█ █▄▀ █▀▀ █▀▄ █▄█ █▄█ █▄▄ █░█ ░█░ █▀█                    ║" Yellow
    Write-Centered "║                                                                      ║" DarkYellow
    Write-Centered "║                         PREMIUM RUNNER                               ║" Yellow
    Write-Centered "║                                                                      ║" DarkYellow
    Write-Centered "╚══════════════════════════════════════════════════════════════════════╝" DarkYellow
    Write-Host ""
    Write-Centered "GitHub Release  ->  Download Package  ->  Open Interface" DarkYellow 1
    Write-Host ""
}

function Show-PremiumBar {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Label,
        [int]$Start = 0,
        [int]$End = 100,
        [int]$Delay = 2
    )

    $barWidth = 52
    $frames = @("◜", "◠", "◝", "◞", "◡", "◟")
    $shine = @("◆", "✦", "◇", "✦")

    Write-Host ""
    Write-Centered $Label Yellow 1

    for ($i = $Start; $i -le $End; $i += 4) {
        if ($i -gt 100) {
            $i = 100
        }

        $filled = [Math]::Floor(($i / 100) * $barWidth)

        if ($filled -lt 0) {
            $filled = 0
        }

        if ($filled -gt $barWidth) {
            $filled = $barWidth
        }

        $empty = $barWidth - $filled
        $spin = $frames[$i % $frames.Count]
        $spark = $shine[$i % $shine.Count]

        $barFull = "█" * $filled
        $barEmpty = "▓" * $empty

        $state = "CONNECTING"

        if ($i -ge 35 -and $i -lt 70) {
            $state = "DOWNLOADING"
        }
        elseif ($i -ge 70 -and $i -lt 100) {
            $state = "FINALIZING"
        }
        elseif ($i -ge 100) {
            $state = "SUCCESSFULLY"
        }

        $width = Get-ConsoleWidthSafe
        $visualLength = $barWidth + 34
        $left = [Math]::Max(0, [Math]::Floor(($width - $visualLength) / 2))

        Write-Host "`r" -NoNewline
        Write-Host (" " * $left) -NoNewline
        Write-Host "$spin " -NoNewline -ForegroundColor White
        Write-Host "╞" -NoNewline -ForegroundColor DarkYellow
        Write-Host $barFull -NoNewline -ForegroundColor Yellow
        Write-Host $barEmpty -NoNewline -ForegroundColor DarkGray
        Write-Host "╡ " -NoNewline -ForegroundColor DarkYellow
        Write-Host ("{0,3}%" -f $i) -NoNewline -ForegroundColor White
        Write-Host "  $spark $state" -NoNewline -ForegroundColor Yellow

        if ($Delay -gt 0) {
            Start-Sleep -Milliseconds $Delay
        }
    }

    Write-Host ""
}

function Show-Successfully {
    Write-Host ""
    Write-Centered "SUCCESSFULLY" Green 2
    Start-Sleep -Milliseconds 100
}

function Ensure-InstallDir {
    if (-not (Test-Path -LiteralPath $InstallDir)) {
        New-Item -ItemType Directory -Path $InstallDir -Force | Out-Null
    }

    if (-not (Test-Path -LiteralPath $PackageDir)) {
        New-Item -ItemType Directory -Path $PackageDir -Force | Out-Null
    }

    if (-not (Test-Path -LiteralPath $RuntimeTempDir)) {
        New-Item -ItemType Directory -Path $RuntimeTempDir -Force | Out-Null
    }
}

function Prepare-RuntimeTemp {
    try {
        if (Test-Path -LiteralPath $RuntimeTempDir) {
            Remove-Item -LiteralPath $RuntimeTempDir -Recurse -Force -ErrorAction SilentlyContinue
        }

        New-Item -ItemType Directory -Path $RuntimeTempDir -Force | Out-Null
    }
    catch {
        throw "Cannot prepare runtime temp folder: $RuntimeTempDir"
    }
}

function Invoke-GitHubApi {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Uri
    )

    $headers = @{
        "User-Agent" = "GODPROJEXTH"
        "Accept" = "application/vnd.github+json"
        "Cache-Control" = "no-cache"
    }

    return Invoke-RestMethod -Uri $Uri -Headers $headers -Method Get
}

function Get-LatestRelease {
    $latestUri = "https://api.github.com/repos/$RepoOwner/$RepoName/releases/latest"

    try {
        return Invoke-GitHubApi -Uri $latestUri
    }
    catch {
        throw "Cannot read latest release from GitHub. Make sure repo is public and release exists."
    }
}

function Get-AllReleases {
    $releasesUri = "https://api.github.com/repos/$RepoOwner/$RepoName/releases?per_page=30"

    try {
        $releases = Invoke-GitHubApi -Uri $releasesUri

        if ($null -eq $releases) {
            return @()
        }

        return @($releases)
    }
    catch {
        return @()
    }
}

function Get-AssetNamesText {
    param(
        [array]$Assets
    )

    if ($null -eq $Assets -or $Assets.Count -eq 0) {
        return "No uploaded release assets found."
    }

    $names = @()

    foreach ($asset in $Assets) {
        if ($null -ne $asset.name) {
            $names += $asset.name
        }
    }

    if ($names.Count -eq 0) {
        return "No asset names found."
    }

    return ($names -join ", ")
}

function Select-ZipAssetFromAssets {
    param(
        [array]$Assets
    )

    if ($null -eq $Assets -or $Assets.Count -eq 0) {
        return $null
    }

    $exact = $Assets | Where-Object { $_.name -ieq $PreferredZipName } | Select-Object -First 1

    if ($exact -and -not [string]::IsNullOrWhiteSpace($exact.browser_download_url)) {
        return @{
            Url = $exact.browser_download_url
            Name = $exact.name
            Size = [int64]$exact.size
            Source = "release-zip-exact"
            Type = "zip"
        }
    }

    foreach ($possibleName in $PossibleZipNames) {
        $match = $Assets | Where-Object { $_.name -ieq $possibleName } | Select-Object -First 1

        if ($match -and -not [string]::IsNullOrWhiteSpace($match.browser_download_url)) {
            return @{
                Url = $match.browser_download_url
                Name = $match.name
                Size = [int64]$match.size
                Source = "release-zip-known"
                Type = "zip"
            }
        }
    }

    $zipAssets = @($Assets | Where-Object { $_.name -match "\.zip$" -and $_.name -notmatch "Source code" })

    if ($zipAssets.Count -eq 1) {
        return @{
            Url = $zipAssets[0].browser_download_url
            Name = $zipAssets[0].name
            Size = [int64]$zipAssets[0].size
            Source = "release-single-zip"
            Type = "zip"
        }
    }

    return $null
}

function Select-ExeAssetFromAssets {
    param(
        [array]$Assets
    )

    if ($null -eq $Assets -or $Assets.Count -eq 0) {
        return $null
    }

    $exact = $Assets | Where-Object { $_.name -ieq $PreferredExeName } | Select-Object -First 1

    if ($exact -and -not [string]::IsNullOrWhiteSpace($exact.browser_download_url)) {
        return @{
            Url = $exact.browser_download_url
            Name = $exact.name
            Size = [int64]$exact.size
            Source = "release-exe-exact"
            Type = "exe"
        }
    }

    foreach ($possibleName in $PossibleExeNames) {
        $match = $Assets | Where-Object { $_.name -ieq $possibleName } | Select-Object -First 1

        if ($match -and -not [string]::IsNullOrWhiteSpace($match.browser_download_url)) {
            return @{
                Url = $match.browser_download_url
                Name = $match.name
                Size = [int64]$match.size
                Source = "release-exe-known"
                Type = "exe"
            }
        }
    }

    $exeAssets = @($Assets | Where-Object { $_.name -match "\.exe$" })

    if ($exeAssets.Count -eq 1) {
        return @{
            Url = $exeAssets[0].browser_download_url
            Name = $exeAssets[0].name
            Size = [int64]$exeAssets[0].size
            Source = "release-single-exe"
            Type = "exe"
        }
    }

    if ($exeAssets.Count -gt 1) {
        $names = Get-AssetNamesText -Assets $exeAssets
        throw "Multiple EXE assets found: $names. Keep only one EXE asset or rename one to $PreferredExeName."
    }

    return $null
}

function Get-GitHubPackageInfo {
    $latest = Get-LatestRelease
    $latestAssets = @()

    if ($null -ne $latest.assets) {
        $latestAssets = @($latest.assets)
    }

    $zipSelected = Select-ZipAssetFromAssets -Assets $latestAssets

    if ($null -ne $zipSelected) {
        return $zipSelected
    }

    $exeSelected = Select-ExeAssetFromAssets -Assets $latestAssets

    if ($null -ne $exeSelected) {
        return $exeSelected
    }

    $latestAssetNames = Get-AssetNamesText -Assets $latestAssets
    $allReleases = Get-AllReleases

    foreach ($release in $allReleases) {
        $assets = @()

        if ($null -ne $release.assets) {
            $assets = @($release.assets)
        }

        $zipFromRelease = Select-ZipAssetFromAssets -Assets $assets

        if ($null -ne $zipFromRelease) {
            return $zipFromRelease
        }

        $exeFromRelease = Select-ExeAssetFromAssets -Assets $assets

        if ($null -ne $exeFromRelease) {
            return $exeFromRelease
        }
    }

    foreach ($possibleName in $PossibleZipNames) {
        $rawUrl = "https://raw.githubusercontent.com/$RepoOwner/$RepoName/main/$possibleName"

        try {
            $null = Invoke-WebRequest -Uri $rawUrl -Method Head -UseBasicParsing

            return @{
                Url = $rawUrl
                Name = $possibleName
                Size = 0
                Source = "main-branch-raw-zip"
                Type = "zip"
            }
        }
        catch {
        }
    }

    foreach ($possibleName in $PossibleExeNames) {
        $rawUrl = "https://raw.githubusercontent.com/$RepoOwner/$RepoName/main/$possibleName"

        try {
            $null = Invoke-WebRequest -Uri $rawUrl -Method Head -UseBasicParsing

            return @{
                Url = $rawUrl
                Name = $possibleName
                Size = 0
                Source = "main-branch-raw-exe"
                Type = "exe"
            }
        }
        catch {
        }
    }

    throw "Package not found. Latest release assets: $latestAssetNames. Upload GODPROJEXTH_PORTABLE.zip built with PyInstaller --onedir."
}

function Save-FileFromUrl {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Url,
        [Parameter(Mandatory = $true)]
        [string]$OutputPath,
        [Parameter(Mandatory = $true)]
        [string]$TempPath,
        [int64]$RemoteSize
    )

    $lastError = $null

    for ($attempt = 1; $attempt -le $DownloadRetryCount; $attempt++) {
        try {
            if (Test-Path -LiteralPath $TempPath) {
                Remove-Item -LiteralPath $TempPath -Force -ErrorAction SilentlyContinue
            }

            Invoke-WebRequest -Uri $Url -OutFile $TempPath -UseBasicParsing

            if (-not (Test-Path -LiteralPath $TempPath)) {
                throw "Temporary download file was not created."
            }

            $downloaded = Get-Item -LiteralPath $TempPath

            if ($downloaded.Length -lt 10240) {
                throw "Downloaded file is too small."
            }

            if ($RemoteSize -gt 0 -and $downloaded.Length -ne $RemoteSize) {
                throw "Downloaded size mismatch. Expected $RemoteSize bytes, got $($downloaded.Length) bytes."
            }

            if (Test-Path -LiteralPath $OutputPath) {
                Remove-Item -LiteralPath $OutputPath -Force -ErrorAction SilentlyContinue
            }

            Move-Item -LiteralPath $TempPath -Destination $OutputPath -Force

            try {
                Unblock-File -LiteralPath $OutputPath -ErrorAction SilentlyContinue
            }
            catch {
            }

            return
        }
        catch {
            $lastError = $_.Exception.Message

            if (Test-Path -LiteralPath $TempPath) {
                Remove-Item -LiteralPath $TempPath -Force -ErrorAction SilentlyContinue
            }

            Start-Sleep -Milliseconds 350
        }
    }

    throw "Download failed after $DownloadRetryCount attempts. Last error: $lastError"
}

function Clear-PackageDirectory {
    if (Test-Path -LiteralPath $PackageDir) {
        Remove-Item -LiteralPath $PackageDir -Recurse -Force -ErrorAction SilentlyContinue
    }

    New-Item -ItemType Directory -Path $PackageDir -Force | Out-Null
}

function Expand-ZipPackage {
    param(
        [Parameter(Mandatory = $true)]
        [string]$ZipFile
    )

    Clear-PackageDirectory

    try {
        Expand-Archive -LiteralPath $ZipFile -DestinationPath $PackageDir -Force
    }
    catch {
        throw "Cannot extract ZIP package. Rebuild ZIP and upload again."
    }
}

function Find-ExeInsidePackage {
    $exact = Get-ChildItem -LiteralPath $PackageDir -Filter $PreferredExeName -Recurse -ErrorAction SilentlyContinue | Select-Object -First 1

    if ($null -ne $exact) {
        return $exact.FullName
    }

    foreach ($possibleName in $PossibleExeNames) {
        $match = Get-ChildItem -LiteralPath $PackageDir -Filter $possibleName -Recurse -ErrorAction SilentlyContinue | Select-Object -First 1

        if ($null -ne $match) {
            return $match.FullName
        }
    }

    $allExe = @(Get-ChildItem -LiteralPath $PackageDir -Filter "*.exe" -Recurse -ErrorAction SilentlyContinue)

    if ($allExe.Count -eq 1) {
        return $allExe[0].FullName
    }

    if ($allExe.Count -gt 1) {
        $names = ($allExe | ForEach-Object { $_.Name }) -join ", "
        throw "Multiple EXE files found inside ZIP: $names. Keep only one main EXE or name it $PreferredExeName."
    }

    throw "No EXE found inside ZIP package."
}

function Download-Package {
    Ensure-InstallDir

    Write-Status "Connecting to GitHub release." Green

    $packageInfo = Get-GitHubPackageInfo
    $packageUrl = $packageInfo.Url
    $packageName = $packageInfo.Name
    $packageSource = $packageInfo.Source
    $packageType = $packageInfo.Type
    $packageSize = [int64]$packageInfo.Size

    Show-PremiumBar -Label "Checking premium package" -Start 1 -End 20 -Delay 2

    Write-Status "Found package: $packageName" Green
    Write-Status "Source: $packageSource" Yellow
    Write-Status "Type: $packageType" Yellow

    Show-PremiumBar -Label "Downloading GODPROJEXTH interface" -Start 21 -End 70 -Delay 2

    if ($packageType -eq "zip") {
        Save-FileFromUrl -Url $packageUrl -OutputPath $ZipPath -TempPath $TempZipPath -RemoteSize $packageSize
        return @{
            Type = "zip"
            Path = $ZipPath
        }
    }

    if ($packageType -eq "exe") {
        Save-FileFromUrl -Url $packageUrl -OutputPath $FallbackExePath -TempPath $TempExePath -RemoteSize $packageSize
        return @{
            Type = "exe"
            Path = $FallbackExePath
        }
    }

    throw "Unknown package type."
}

function Verify-Package {
    param(
        [Parameter(Mandatory = $true)]
        [hashtable]$Package
    )

    if ($Package.Type -eq "zip") {
        if ([string]::IsNullOrWhiteSpace($ExpectedZipSha256)) {
            Write-Status "ZIP SHA256 skipped." Yellow
            Show-PremiumBar -Label "Preparing verified package" -Start 71 -End 84 -Delay 1
            return
        }

        $actualZip = (Get-FileHash -Algorithm SHA256 -Path $Package.Path).Hash.ToUpperInvariant()
        $expectedZip = $ExpectedZipSha256.ToUpperInvariant()

        if ($actualZip -ne $expectedZip) {
            Remove-Item -LiteralPath $Package.Path -Force -ErrorAction SilentlyContinue
            throw "ZIP SHA256 mismatch."
        }

        return
    }

    if ($Package.Type -eq "exe") {
        if ([string]::IsNullOrWhiteSpace($ExpectedExeSha256)) {
            Write-Status "EXE SHA256 skipped." Yellow
            Show-PremiumBar -Label "Preparing verified package" -Start 71 -End 84 -Delay 1
            return
        }

        $actualExe = (Get-FileHash -Algorithm SHA256 -Path $Package.Path).Hash.ToUpperInvariant()
        $expectedExe = $ExpectedExeSha256.ToUpperInvariant()

        if ($actualExe -ne $expectedExe) {
            Remove-Item -LiteralPath $Package.Path -Force -ErrorAction SilentlyContinue
            throw "EXE SHA256 mismatch."
        }

        return
    }
}

function Prepare-Executable {
    param(
        [Parameter(Mandatory = $true)]
        [hashtable]$Package
    )

    if ($Package.Type -eq "zip") {
        Write-Status "Extracting portable package." Green
        Show-PremiumBar -Label "Extracting GODPROJEXTH package" -Start 85 -End 92 -Delay 1
        Expand-ZipPackage -ZipFile $Package.Path
        $exeInside = Find-ExeInsidePackage
        return $exeInside
    }

    if ($Package.Type -eq "exe") {
        Write-Status "Using onefile EXE fallback." Yellow
        Show-PremiumBar -Label "Preparing onefile runtime" -Start 85 -End 92 -Delay 1
        return $Package.Path
    }

    throw "Cannot prepare executable."
}

function Open-GuiExe {
    param(
        [Parameter(Mandatory = $true)]
        [string]$ExecutablePath
    )

    Write-Status "Preparing clean runtime temp." Green
    Prepare-RuntimeTemp

    Write-Status "Opening premium interface." Green
    Show-PremiumBar -Label "Opening interface" -Start 93 -End 100 -Delay 1
    Show-Successfully

    $oldTemp = $env:TEMP
    $oldTmp = $env:TMP

    try {
        $env:TEMP = $RuntimeTempDir
        $env:TMP = $RuntimeTempDir

        $workingDirectory = Split-Path -Parent $ExecutablePath

        Start-Process -FilePath $ExecutablePath -WorkingDirectory $workingDirectory
    }
    finally {
        $env:TEMP = $oldTemp
        $env:TMP = $oldTmp
    }
}

function Exit-Runner {
    Start-Sleep -Milliseconds 80

    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    [System.Environment]::Exit(0)
}

try {
    Initialize-Console
    Show-Header

    $package = Download-Package
    Verify-Package -Package $package
    $executable = Prepare-Executable -Package $package
    Open-GuiExe -ExecutablePath $executable
    Exit-Runner
}
catch {
    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    Write-Host ""
    Write-Host "   [GODPROJEXTH ERROR]" -ForegroundColor Red
    Write-Host "   $($_.Exception.Message)" -ForegroundColor Red
    Write-Host ""
    Write-Host "   วิธีแก้ PySide6 / MSVCP140.dll decompression error:" -ForegroundColor Yellow
    Write-Host "   1. Build ใหม่ด้วยคำสั่งนี้:" -ForegroundColor Yellow
    Write-Host "      pyinstaller --noconfirm --clean --onedir --windowed --name `"POWERSHELLGODPROJEXTH`" Powershell.py" -ForegroundColor Yellow
    Write-Host "   2. Zip ทั้งโฟลเดอร์ dist\POWERSHELLGODPROJEXTH" -ForegroundColor Yellow
    Write-Host "   3. ตั้งชื่อ ZIP เป็น GODPROJEXTH_PORTABLE.zip" -ForegroundColor Yellow
    Write-Host "   4. Upload ZIP เข้า GitHub Release Assets" -ForegroundColor Yellow
    Write-Host "   5. กด Update release" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "   Release page:" -ForegroundColor Yellow
    Write-Host "   https://github.com/$RepoOwner/$RepoName/releases/latest" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "   Install path:" -ForegroundColor Yellow
    Write-Host "   $InstallDir" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "   Press Enter to close..." -ForegroundColor Yellow
    [void][System.Console]::ReadLine()
}
