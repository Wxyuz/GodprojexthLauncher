$ErrorActionPreference = "Stop"
$ProgressPreference = "SilentlyContinue"
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

$RepoOwner = "Wxyuz"
$RepoName = "GodprojexthLauncher"
$PayloadFileName = "Powershell.py"

$AppRoot = Join-Path $env:LOCALAPPDATA "GodprojexthPremium"
$PayloadPath = Join-Path $AppRoot "Powershell.py"
$LogPath = Join-Path $AppRoot "launch_error.log"

$RequiredModules = @(
    @{ ImportName = "PySide6"; PackageName = "PySide6" },
    @{ ImportName = "requests"; PackageName = "requests" },
    @{ ImportName = "PIL"; PackageName = "Pillow" },
    @{ ImportName = "psutil"; PackageName = "psutil" }
)

function Initialize-Console {
    try {
        [Console]::OutputEncoding = [System.Text.Encoding]::UTF8
        [Console]::InputEncoding = [System.Text.Encoding]::UTF8
        [Console]::CursorVisible = $false
    }
    catch {
    }

    try {
        $Host.UI.RawUI.WindowTitle = "GODPROJEXTH PREMIUM RUNNER"

        $buffer = $Host.UI.RawUI.BufferSize
        $window = $Host.UI.RawUI.WindowSize
        $max = $Host.UI.RawUI.MaxPhysicalWindowSize

        $targetWidth = [Math]::Min(118, $max.Width)
        $targetHeight = [Math]::Min(34, $max.Height)

        if ($buffer.Width -lt $targetWidth) {
            $Host.UI.RawUI.BufferSize = New-Object System.Management.Automation.Host.Size($targetWidth, [Math]::Max($buffer.Height, 3000))
        }

        if ($window.Width -lt 100) {
            $Host.UI.RawUI.WindowSize = New-Object System.Management.Automation.Host.Size($targetWidth, $targetHeight)
        }
    }
    catch {
    }

    Clear-Host
}

function Get-ConsoleWidthSafe {
    try {
        return [Math]::Max(80, $Host.UI.RawUI.WindowSize.Width)
    }
    catch {
        return 100
    }
}

function Write-Typed {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Text,

        [System.ConsoleColor]$Color = [System.ConsoleColor]::Yellow,

        [int]$Delay = 18,

        [switch]$NoNewLine
    )

    foreach ($char in $Text.ToCharArray()) {
        Write-Host $char -NoNewline -ForegroundColor $Color
        Start-Sleep -Milliseconds $Delay
    }

    if (-not $NoNewLine) {
        Write-Host ""
    }
}

function Write-Centered {
    param(
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::Yellow,
        [int]$Delay = 0
    )

    $width = Get-ConsoleWidthSafe
    $left = [Math]::Max(0, [Math]::Floor(($width - $Text.Length) / 2))
    $line = (" " * $left) + $Text

    if ($Delay -le 0) {
        Write-Host $line -ForegroundColor $Color
    }
    else {
        foreach ($char in $line.ToCharArray()) {
            Write-Host $char -NoNewline -ForegroundColor $Color
            Start-Sleep -Milliseconds $Delay
        }
        Write-Host ""
    }
}

function Write-Status {
    param(
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::Green,
        [int]$Delay = 10
    )

    Write-Host "   " -NoNewline
    Write-Typed "[GODPROJEXTH] $Text" $Color $Delay
}

function Get-BigTextLines {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Text
    )

    $glyphs = @{
        "A" = @("  █  "," █ █ ","█████","█   █","█   █")
        "D" = @("████ ","█   █","█   █","█   █","████ ")
        "E" = @("█████","█    ","████ ","█    ","█████")
        "G" = @(" ████","█    ","█ ███","█   █"," ███ ")
        "H" = @("█   █","█   █","█████","█   █","█   █")
        "J" = @("  ███","   █ ","   █ ","█  █ "," ██  ")
        "L" = @("█    ","█    ","█    ","█    ","█████")
        "O" = @(" ███ ","█   █","█   █","█   █"," ███ ")
        "P" = @("████ ","█   █","████ ","█    ","█    ")
        "R" = @("████ ","█   █","████ ","█  █ ","█   █")
        "T" = @("█████","  █  ","  █  ","  █  ","  █  ")
        "X" = @("█   █"," █ █ ","  █  "," █ █ ","█   █")
        " " = @("     ","     ","     ","     ","     ")
    }

    $result = @("", "", "", "", "")
    $chars = $Text.ToUpperInvariant().ToCharArray()

    foreach ($char in $chars) {
        $key = [string]$char

        if (-not $glyphs.ContainsKey($key)) {
            $key = " "
        }

        for ($i = 0; $i -lt 5; $i++) {
            $result[$i] += $glyphs[$key][$i] + " "
        }
    }

    return $result
}

function Write-BigText {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Text,

        [System.ConsoleColor]$Color = [System.ConsoleColor]::Yellow,

        [int]$Delay = 1
    )

    $lines = Get-BigTextLines -Text $Text

    foreach ($line in $lines) {
        Write-Centered $line $Color $Delay
        Start-Sleep -Milliseconds 35
    }
}

function Write-PremiumFrameTop {
    $width = Get-ConsoleWidthSafe
    $inner = [Math]::Min(86, [Math]::Max(58, $width - 16))
    Write-Centered ("╔" + ("═" * $inner) + "╗") DarkYellow 0
}

function Write-PremiumFrameBottom {
    $width = Get-ConsoleWidthSafe
    $inner = [Math]::Min(86, [Math]::Max(58, $width - 16))
    Write-Centered ("╚" + ("═" * $inner) + "╝") DarkYellow 0
}

function Show-GodprojexthArt {
    Write-PremiumFrameTop
    Write-Host ""
    Write-BigText "GODPROJEXTH" Yellow 1
    Write-Host ""
    Write-PremiumFrameBottom
}

function Show-AlphaGodprojexthArt {
    Write-PremiumFrameTop
    Write-Host ""
    Write-BigText "ALPHA" Yellow 1
    Write-Host ""
    Write-BigText "GODPROJEXTH" Yellow 1
    Write-Host ""
    Write-PremiumFrameBottom
}

function Show-Header {
    Clear-Host
    Write-Host ""
    Show-GodprojexthArt
    Write-Host ""
    Write-Centered "GODPROJEXTH PREMIUM RUNNER" Yellow 18
    Write-Centered "Secure Load  ->  Premium Connect  ->  Open Interface" DarkYellow 12
    Write-Host ""
}

function Show-PremiumBar {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Label,

        [int]$Start = 0,

        [int]$End = 100,

        [int]$Delay = 28
    )

    $barWidth = 46
    $frames = @("◜", "◠", "◝", "◞", "◡", "◟")
    $pulse = @("◇", "◆", "✦", "◆")

    Write-Host ""
    Write-Centered $Label Yellow 12

    for ($i = $Start; $i -le $End; $i++) {
        $filled = [Math]::Floor(($i / 100) * $barWidth)

        if ($filled -lt 0) {
            $filled = 0
        }

        if ($filled -gt $barWidth) {
            $filled = $barWidth
        }

        $empty = $barWidth - $filled
        $spin = $frames[$i % $frames.Count]
        $spark = $pulse[$i % $pulse.Count]

        $fillText = "█" * $filled
        $emptyText = "░" * $empty

        $state = "CONNECTING"

        if ($i -ge 35 -and $i -lt 70) {
            $state = "LOADING"
        }
        elseif ($i -ge 70) {
            $state = "FINALIZING"
        }

        $width = Get-ConsoleWidthSafe
        $visualLength = $barWidth + 28
        $left = [Math]::Max(0, [Math]::Floor(($width - $visualLength) / 2))

        Write-Host "`r" -NoNewline
        Write-Host (" " * $left) -NoNewline
        Write-Host "$spin " -NoNewline -ForegroundColor White
        Write-Host "╞" -NoNewline -ForegroundColor DarkYellow
        Write-Host $fillText -NoNewline -ForegroundColor Yellow
        Write-Host $emptyText -NoNewline -ForegroundColor DarkGray
        Write-Host "╡ " -NoNewline -ForegroundColor DarkYellow
        Write-Host ("{0,3}%" -f $i) -NoNewline -ForegroundColor White
        Write-Host "  " -NoNewline
        Write-Host $spark -NoNewline -ForegroundColor Yellow
        Write-Host " $state" -NoNewline -ForegroundColor DarkYellow

        Start-Sleep -Milliseconds $Delay
    }

    Write-Host ""
    Write-Host ""
}

function Show-CreditLine {
    param(
        [string]$Name,
        [string]$Value
    )

    $line = ("{0,-8} : {1}" -f $Name, $Value)
    Write-Centered $line Yellow 14
}

function Show-EndCredits {
    Clear-Host
    Write-Host ""
    Show-AlphaGodprojexthArt
    Write-Host ""

    Write-Centered "PREMIUM INTERFACE READY..." Yellow 16
    Write-Host ""

    Show-PremiumBar -Label "Finalizing premium interface" -Start 90 -End 100 -Delay 42

    Write-Centered "╭────────────────────────────────────────────╮" DarkYellow 0
    Show-CreditLine "WEBSITE" "GODPROJEXTH"
    Show-CreditLine "YOUTUBE" "GODPROJEXTH"
    Show-CreditLine "TIKTOK" "GODPROJEXTH"
    Show-CreditLine "DISCORD" "GODPROJEXTH"
    Write-Centered "╰────────────────────────────────────────────╯" DarkYellow 0
    Write-Host ""

    Start-Sleep -Milliseconds 900
}

function Ensure-Folder {
    param([string]$Path)

    if (-not (Test-Path -LiteralPath $Path)) {
        New-Item -ItemType Directory -Path $Path -Force | Out-Null
    }
}

function Find-Engine {
    $candidates = New-Object System.Collections.ArrayList

    $searchRoots = @(
        "$env:LOCALAPPDATA\Programs\Python",
        "$env:LOCALAPPDATA\Python"
    )

    foreach ($root in $searchRoots) {
        try {
            if (Test-Path -LiteralPath $root) {
                $found = Get-ChildItem -Path $root -Filter "python.exe" -Recurse -ErrorAction SilentlyContinue |
                    Sort-Object FullName -Descending |
                    Select-Object -First 1

                if ($found) {
                    [void]$candidates.Add(@{
                        File = $found.FullName
                        Args = @()
                    })
                }
            }
        }
        catch {
        }
    }

    $pyLauncher = Get-Command "py.exe" -ErrorAction SilentlyContinue

    if ($pyLauncher -and ($pyLauncher.Source -notlike "*\WindowsApps\*")) {
        [void]$candidates.Add(@{
            File = $pyLauncher.Source
            Args = @("-3")
        })
    }

    $pythonExe = Get-Command "python.exe" -ErrorAction SilentlyContinue

    if ($pythonExe -and ($pythonExe.Source -notlike "*\WindowsApps\*")) {
        [void]$candidates.Add(@{
            File = $pythonExe.Source
            Args = @()
        })
    }

    foreach ($candidate in $candidates) {
        try {
            $args = @()
            $args += $candidate.Args
            $args += @("-c", "import sys; print(sys.version_info.major)")

            $result = & $candidate.File @args 2>$null

            if ($LASTEXITCODE -eq 0 -and (($result -join "").Trim() -eq "3")) {
                return $candidate
            }
        }
        catch {
        }
    }

    return $null
}

function Get-WindowedEngine {
    param($Runtime)

    try {
        if ((Split-Path -Leaf $Runtime.File).ToLower() -eq "python.exe") {
            $folder = Split-Path -Parent $Runtime.File
            $pythonw = Join-Path $folder "pythonw.exe"

            if (Test-Path -LiteralPath $pythonw) {
                return @{
                    File = $pythonw
                    Args = @()
                }
            }
        }

        $pyw = Get-Command "pyw.exe" -ErrorAction SilentlyContinue

        if ($pyw -and ($pyw.Source -notlike "*\WindowsApps\*")) {
            return @{
                File = $pyw.Source
                Args = @("-3")
            }
        }
    }
    catch {
    }

    return $Runtime
}

function Get-ConsoleEngine {
    param($Runtime)

    try {
        if ((Split-Path -Leaf $Runtime.File).ToLower() -eq "pythonw.exe") {
            $folder = Split-Path -Parent $Runtime.File
            $python = Join-Path $folder "python.exe"

            if (Test-Path -LiteralPath $python) {
                return @{
                    File = $python
                    Args = @()
                }
            }
        }
    }
    catch {
    }

    return $Runtime
}

function Get-PayloadUrl {
    $releaseApi = "https://api.github.com/repos/$RepoOwner/$RepoName/releases/latest"

    try {
        $headers = @{
            "User-Agent" = "GODPROJEXTH"
            "Accept" = "application/vnd.github+json"
        }

        $release = Invoke-RestMethod -Uri $releaseApi -Headers $headers -Method Get

        if ($null -ne $release -and $null -ne $release.assets) {
            $asset = $release.assets | Where-Object { $_.name -eq $PayloadFileName } | Select-Object -First 1

            if ($asset -and -not [string]::IsNullOrWhiteSpace($asset.browser_download_url)) {
                return $asset.browser_download_url
            }
        }
    }
    catch {
    }

    $rawUrl = "https://raw.githubusercontent.com/$RepoOwner/$RepoName/main/$PayloadFileName"

    try {
        $null = Invoke-WebRequest -Uri $rawUrl -Method Head -UseBasicParsing
        return $rawUrl
    }
    catch {
    }

    throw "Cannot find interface package. Upload the file to Latest Release asset or commit it to main."
}

function Download-Interface {
    Ensure-Folder -Path $AppRoot

    Write-Status "Engine ready." Green
    Show-PremiumBar -Label "Checking secure channel" -Start 1 -End 18 -Delay 40

    $payloadUrl = Get-PayloadUrl

    Write-Status "Premium source verified." Green
    Show-PremiumBar -Label "Connecting to protected source" -Start 19 -End 36 -Delay 36

    Write-Status "Protected package confirmed." Green
    Show-PremiumBar -Label "Downloading premium interface" -Start 37 -End 64 -Delay 32

    try {
        Invoke-WebRequest -Uri $payloadUrl -OutFile $PayloadPath -UseBasicParsing
    }
    catch {
        throw "Download failed. Check your GitHub release asset or repository file."
    }

    if (-not (Test-Path -LiteralPath $PayloadPath)) {
        throw "Download failed. Interface package not found."
    }

    $info = Get-Item -LiteralPath $PayloadPath

    if ($info.Length -lt 150) {
        Remove-Item -LiteralPath $PayloadPath -Force -ErrorAction SilentlyContinue
        throw "Downloaded interface package is incomplete."
    }

    Show-PremiumBar -Label "Preparing launch environment" -Start 65 -End 76 -Delay 30
}

function Test-ModuleInstalled {
    param(
        $Runtime,
        [string]$ImportName
    )

    try {
        $args = @()
        $args += $Runtime.Args
        $args += @("-c", "import $ImportName; print('OK')")

        $output = & $Runtime.File @args 2>$null

        if ($LASTEXITCODE -eq 0 -and (($output -join "").Trim() -eq "OK")) {
            return $true
        }
    }
    catch {
    }

    return $false
}

function Install-ModulePackage {
    param(
        $Runtime,
        [string]$PackageName
    )

    $args = @()
    $args += $Runtime.Args
    $args += @("-m", "pip", "install", "--user", "--upgrade", "--disable-pip-version-check", $PackageName)

    $null = & $Runtime.File @args 2>&1

    if ($LASTEXITCODE -ne 0) {
        throw "A required component could not be installed."
    }
}

function Ensure-Components {
    param($Runtime)

    Write-Status "Checking premium components." Yellow
    Show-PremiumBar -Label "Verifying interface components" -Start 77 -End 89 -Delay 28

    foreach ($module in $RequiredModules) {
        if (-not (Test-ModuleInstalled -Runtime $Runtime -ImportName $module.ImportName)) {
            Install-ModulePackage -Runtime $Runtime -PackageName $module.PackageName
        }
    }
}

function Test-PayloadCanCompile {
    param($Runtime)

    $consoleEngine = Get-ConsoleEngine -Runtime $Runtime

    $args = @()
    $args += $consoleEngine.Args
    $args += @("-m", "py_compile", "`"$PayloadPath`"")

    $output = & $consoleEngine.File @args 2>&1

    if ($LASTEXITCODE -ne 0) {
        $output | Out-File -LiteralPath $LogPath -Encoding UTF8 -Force
        throw "Interface file has an error. Saved details to: $LogPath"
    }
}

function Open-Interface {
    param($Runtime)

    Write-Status "Opening premium interface." Green
    Show-PremiumBar -Label "Opening interface" -Start 90 -End 91 -Delay 50

    Test-PayloadCanCompile -Runtime $Runtime

    $windowed = Get-WindowedEngine -Runtime $Runtime

    $argList = @()
    $argList += $windowed.Args
    $argList += @("`"$PayloadPath`"")

    $process = Start-Process -FilePath $windowed.File -ArgumentList $argList -WorkingDirectory $AppRoot -PassThru

    Start-Sleep -Milliseconds 1500

    if ($process.HasExited) {
        Write-Host ""
        Write-Host "   [GODPROJEXTH DEBUG]" -ForegroundColor Yellow
        Write-Host "   GUI closed immediately. Reopening with visible console to show the error..." -ForegroundColor Yellow
        Write-Host ""

        $consoleEngine = Get-ConsoleEngine -Runtime $Runtime

        $debugArgs = @()
        $debugArgs += $consoleEngine.Args
        $debugArgs += @("`"$PayloadPath`"")

        Start-Process -FilePath $consoleEngine.File -ArgumentList $debugArgs -WorkingDirectory $AppRoot
        Start-Sleep -Milliseconds 1200
        throw "GUI could not stay open. Check the debug console or log file."
    }
}

function Exit-Runner {
    Start-Sleep -Milliseconds 700

    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    [System.Environment]::Exit(0)
}

try {
    Initialize-Console
    Show-Header

    $runtime = Find-Engine

    if ($null -eq $runtime) {
        throw "No compatible engine was found on this system."
    }

    Download-Interface
    Ensure-Components -Runtime $runtime
    Show-EndCredits
    Open-Interface -Runtime $runtime
    Exit-Runner
}
catch {
    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    Write-Host ""
    Write-Host "   [GODPROJEXTH ERROR]" -ForegroundColor Red
    Write-Host "   $($_.Exception.Message)" -ForegroundColor Red

    if (Test-Path -LiteralPath $LogPath) {
        Write-Host ""
        Write-Host "   Log file:" -ForegroundColor Yellow
        Write-Host "   $LogPath" -ForegroundColor Yellow
    }

    Write-Host ""
    Write-Host "   Press Enter to close..." -ForegroundColor Yellow
    [void][System.Console]::ReadLine()
}
