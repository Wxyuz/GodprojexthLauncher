$ErrorActionPreference = "Stop"
$ProgressPreference = "SilentlyContinue"

try {
    [Console]::OutputEncoding = [System.Text.Encoding]::UTF8
    [Console]::CursorVisible = $false
    $Host.UI.RawUI.WindowTitle = "GODPROJEXTH PREMIUM RUNNER"
} catch {}

function Write-Slow {
    param(
        [string]$Text,
        [ConsoleColor]$Color = [ConsoleColor]::Yellow,
        [int]$Delay = 18,
        [switch]$NoNewLine
    )

    foreach ($c in $Text.ToCharArray()) {
        Write-Host $c -NoNewline -ForegroundColor $Color
        Start-Sleep -Milliseconds $Delay
    }

    if (-not $NoNewLine) {
        Write-Host ""
    }
}

function Write-At {
    param(
        [int]$X,
        [int]$Y,
        [string]$Text,
        [ConsoleColor]$Color = [ConsoleColor]::Yellow
    )
    try {
        $Host.UI.RawUI.CursorPosition = New-Object System.Management.Automation.Host.Coordinates($X, $Y)
        Write-Host $Text -ForegroundColor $Color -NoNewline
    } catch {}
}

function Clear-Line {
    param([int]$Y)
    try {
        $w = $Host.UI.RawUI.WindowSize.Width
        $Host.UI.RawUI.CursorPosition = New-Object System.Management.Automation.Host.Coordinates(0, $Y)
        Write-Host (" " * ($w - 1)) -NoNewline
        $Host.UI.RawUI.CursorPosition = New-Object System.Management.Automation.Host.Coordinates(0, $Y)
    } catch {}
}

function Show-Header {
    Clear-Host

    $art = @(
"      █████  ██      ██████  ██   ██  █████ ",
"     ██   ██ ██      ██   ██ ██   ██ ██   ██",
"     ███████ ██      ██████  ███████ ███████",
"     ██   ██ ██      ██      ██   ██ ██   ██",
"     ██   ██ ███████ ██      ██   ██ ██   ██",
"",
"  ██████   ██████  ██████  ██████  ██████   ██████       ██ ███████ ██   ██ ████████ ██   ██",
" ██       ██    ██ ██   ██ ██   ██ ██   ██ ██    ██      ██ ██       ██ ██     ██    ██   ██",
" ██   ███ ██    ██ ██   ██ ██████  ██████  ██    ██      ██ █████     ███      ██    ███████",
" ██    ██ ██    ██ ██   ██ ██      ██   ██ ██    ██ ██   ██ ██       ██ ██     ██    ██   ██",
"  ██████   ██████  ██████  ██      ██   ██  ██████   █████  ███████ ██   ██    ██    ██   ██"
    )

    foreach ($line in $art) {
        Write-Slow $line Yellow 2
    }

    Write-Host ""
    Write-Slow "   PREMIUM INTERFACE READY..." Yellow 14
    Write-Host ""
}

function Show-FancyProgress {
    param(
        [string]$Label,
        [int]$From,
        [int]$To,
        [int]$Delay = 25
    )

    $barWidth = 36
    for ($i = $From; $i -le $To; $i++) {
        $filled = [math]::Floor(($i / 100) * $barWidth)
        $empty  = $barWidth - $filled

        $fillText = "■" * $filled
        $emptyText = "·" * $empty

        $spinner = @("◜","◠","◝","◞","◡","◟")[$i % 6]
        $line = ("{0}  [{1}{2}] {3,3}%%" -f $spinner, $fillText, $emptyText, $i)

        Clear-Line 16
        Write-At 3 16 ($Label + " ") Cyan
        Write-Host $line -ForegroundColor Yellow

        Start-Sleep -Milliseconds $Delay
    }
}

function Pause-Smooth {
    param([int]$Milliseconds = 350)
    Start-Sleep -Milliseconds $Milliseconds
}

function Show-Step {
    param(
        [string]$Text,
        [ConsoleColor]$Color = [ConsoleColor]::Green
    )
    Write-Slow ("   [GODPROJEXTH] " + $Text) $Color 16
}

function Pick-And-OpenLocalFile {
    Add-Type -AssemblyName System.Windows.Forms

    $dialog = New-Object System.Windows.Forms.OpenFileDialog
    $dialog.Title = "Select a file to open"
    $dialog.Filter = "Executable or Python|*.exe;*.py|All files|*.*"
    $dialog.Multiselect = $false

    $result = $dialog.ShowDialog()

    if ($result -ne [System.Windows.Forms.DialogResult]::OK) {
        Write-Host ""
        Write-Slow "   No file selected. Closing..." Yellow 16
        Start-Sleep -Milliseconds 700
        return
    }

    $selected = $dialog.FileName
    $ext = [System.IO.Path]::GetExtension($selected).ToLowerInvariant()

    Write-Host ""
    Show-Step "Selected: $([System.IO.Path]::GetFileName($selected))"

    if ($ext -eq ".exe") {
        Show-Step "Launching local EXE..."
        Start-Process -FilePath $selected
    }
    elseif ($ext -eq ".py") {
        $python = Get-Command python -ErrorAction SilentlyContinue
        if (-not $python) {
            throw "Python was not found in PATH."
        }
        Show-Step "Launching local Python script..."
        Start-Process -FilePath $python.Source -ArgumentList "`"$selected`""
    }
    else {
        Start-Process -FilePath $selected
    }
}

Show-Header

Write-Slow "   Starting premium session..." Yellow 14
Pause-Smooth 250
Show-Step "Initializing visual engine..."
Show-FancyProgress "Loading core" 1 20 22

Show-Step "Preparing interface..."
Show-FancyProgress "Preparing UI" 21 45 22

Show-Step "Validating local environment..."
Show-FancyProgress "Checking system" 46 72 20

Show-Step "Finalizing..."
Show-FancyProgress "Opening session" 73 100 18

Write-Host ""
Write-Slow "   ALPHA GODPROJEXTH" White 28
Write-Slow "   Premium session initialized successfully." Yellow 14
Write-Host ""

Pick-And-OpenLocalFile

try { [Console]::CursorVisible = $true } catch {}
