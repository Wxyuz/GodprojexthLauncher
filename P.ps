    return @(
" ██████╗  ██████╗ ██████╗ ██████╗  ██████╗      ██╗███████╗██╗  ██╗████████╗██╗  ██╗",
"██╔════╝ ██╔═══██╗██╔══██╗██╔══██╗██╔═══██╗     ██║██╔════╝╚██╗██╔╝╚══██╔══╝██║  ██║",
"██║  ███╗██║   ██║██║  ██║██████╔╝██║   ██║     ██║█████╗   ╚███╔╝    ██║   ███████║",
"██║   ██║██║   ██║██║  ██║██╔═══╝ ██║   ██║██   ██║██╔══╝   ██╔██╗    ██║   ██╔══██║",
"╚██████╔╝╚██████╔╝██████╔╝██║     ╚██████╔╝╚█████╔╝███████╗██╔╝ ██╗   ██║   ██║  ██║",
" ╚═════╝  ╚═════╝ ╚═════╝ ╚═╝      ╚═════╝  ╚════╝ ╚══════╝╚═╝  ╚═╝   ╚═╝   ╚═╝  ╚═╝"
    )
}

function Draw-GodprojexthHeader {
    $art = Get-GodprojexthArt
    Clear-Host
    Write-Host ""

    for ($i = 0; $i -lt $art.Count; $i++) {
        if ($i -eq 0) {
            Write-Host ("  " + $art[$i]) -ForegroundColor White
        }
        elseif ($i -eq 1 -or $i -eq 2) {
            Write-Host ("  " + $art[$i]) -ForegroundColor Yellow
        }
        else {
            Write-Host ("  " + $art[$i]) -ForegroundColor DarkYellow
        }
    }

    Write-Host ""
    Write-Host "  PREMIUM ALPHA LOADER" -ForegroundColor Yellow
    Write-Host "  Secure interface boot sequence" -ForegroundColor DarkYellow
    Write-Host ""
    Write-Host "  ┌──────────────────────────────────────────────────────────────┐" -ForegroundColor DarkYellow
    Write-Host "  │                                                              │    0%" -ForegroundColor DarkYellow
    Write-Host "  └──────────────────────────────────────────────────────────────┘" -ForegroundColor DarkYellow
    Write-Host ""
    Write-Host "  Stage  : 0000" -ForegroundColor DarkYellow
    Write-Host "  Stream : waiting..." -ForegroundColor DarkYellow
}

function Draw-ProtectedLoader {
    param(
        [string]$Status,
        [int]$Percent,
        [int]$Frame
    )

    $Percent = [Math]::Max(0, [Math]::Min(100, $Percent))
    $barWidth = 62
    $filled = [int][Math]::Floor(($Percent / 100) * $barWidth)

    if ($filled -lt 0) {
        $filled = 0
    }

    if ($filled -gt $barWidth) {
        $filled = $barWidth
    }

    $empty = $barWidth - $filled

    if ($filled -eq 0) {
        $bar = " " * $barWidth
    }
    elseif ($filled -ge $barWidth) {
        $bar = "▓" * $barWidth
    }
    else {
        $bar = ("▓" * $filled) + ("░" * $empty)
    }

    $scannerWidth = 62
    $scannerPos = $Frame % $scannerWidth
    $scanner = ""

    for ($i = 0; $i -lt $scannerWidth; $i++) {
        if ($i -eq $scannerPos) {
            $scanner += "◆"
        }
        elseif (($i + 1) -eq $scannerPos -or ($i - 1) -eq $scannerPos) {
            $scanner += "•"
        }
        else {
            $scanner += "·"
        }
    }

    $spinnerChars = @("◐", "◓", "◑", "◒")
    $spinner = $spinnerChars[$Frame % $spinnerChars.Count]

    Safe-WriteLine -Top 10 -Text ("  Status : {0} {1}" -f $Status, $spinner) -Color Yellow
    Safe-WriteLine -Top 12 -Text ("  │{0}│  {1,3}%" -f $bar, $Percent) -Color Yellow
    Safe-WriteLine -Top 15 -Text ("  Stage  : {0:0000}" -f $Frame) -Color DarkYellow
    Safe-WriteLine -Top 16 -Text ("  Stream : {0}" -f $scanner) -Color DarkYellow
}

function Animate-ToPercent {
    param(
        [int]$From,
        [int]$To,
        [string]$Status,
        [ref]$FrameRef
    )

    if ($To -lt $From) {
        $To = $From
    }

    for ($value = $From; $value -le $To; $value++) {
        Draw-ProtectedLoader -Status $Status -Percent $value -Frame $FrameRef.Value
        $FrameRef.Value++
        Start-Sleep -Milliseconds 14
    }

    return $To
}

function Get-PremiumArt {
    return @(
"██████╗ ██████╗ ███████╗███╗   ███╗██╗██╗   ██╗███╗   ███╗",
"██╔══██╗██╔══██╗██╔════╝████╗ ████║██║██║   ██║████╗ ████║",
"██████╔╝██████╔╝█████╗  ██╔████╔██║██║██║   ██║██╔████╔██║",
"██╔═══╝ ██╔══██╗██╔══╝  ██║╚██╔╝██║██║██║   ██║██║╚██╔╝██║",
"██║     ██║  ██║███████╗██║ ╚═╝ ██║██║╚██████╔╝██║ ╚═╝ ██║",
"╚═╝     ╚═╝  ╚═╝╚══════╝╚═╝     ╚═╝╚═╝ ╚═════╝ ╚═╝     ╚═╝"
    )
}

function Show-GodprojexthCredit {
    param([ref]$FrameRef)

    Clear-Host
    Write-Host ""
    Write-Host "  ✦ GODPROJEXTH PREMIUM CREDIT ✦" -ForegroundColor Yellow
    Write-Host ""

    $premium = Get-PremiumArt
    $god = Get-GodprojexthArt

    for ($column = 1; $column -le 70; $column++) {
        for ($row = 0; $row -lt $premium.Count; $row++) {
            $line = $premium[$row]

            if ($column -gt $line.Length) {
                $part = $line
            }
            else {
                $part = $line.Substring(0, [Math]::Min($column, $line.Length))
            }

            $color = if ($row -eq 0) { [System.ConsoleColor]::White } elseif ($row -lt 3) { [System.ConsoleColor]::Yellow } else { [System.ConsoleColor]::DarkYellow }
            Safe-WriteLine -Top (3 + $row) -Text ("  " + $part) -Color $color
        }

        $FrameRef.Value++
        Start-Sleep -Milliseconds 10
    }

    Start-Sleep -Milliseconds 120
    Clear-Host
    Write-Host ""
    Write-Host "  ✦ PREMIUM GODPROJEXTH ✦" -ForegroundColor Yellow
    Write-Host ""

    for ($column = 1; $column -le 96; $column++) {
        for ($row = 0; $row -lt $god.Count; $row++) {
            $line = $god[$row]

            if ($column -gt $line.Length) {
                $part = $line
            }
            else {
                $part = $line.Substring(0, [Math]::Min($column, $line.Length))
            }

            $color = if ($row -eq 0) { [System.ConsoleColor]::White } elseif ($row -lt 3) { [System.ConsoleColor]::Yellow } else { [System.ConsoleColor]::DarkYellow }
            Safe-WriteLine -Top (3 + $row) -Text ("  " + $part) -Color $color
        }

        Safe-WriteLine -Top 11 -Text ("  Launching interface  frame {0:0000}" -f $FrameRef.Value) -Color DarkYellow
        $FrameRef.Value++
        Start-Sleep -Milliseconds 9
    }

    for ($shine = 0; $shine -lt 26; $shine++) {
        for ($row = 0; $row -lt $god.Count; $row++) {
            $phase = ($shine + $row) % 5
            $color = if ($phase -eq 0) { [System.ConsoleColor]::White } elseif ($phase -lt 3) { [System.ConsoleColor]::Yellow } else { [System.ConsoleColor]::DarkYellow }
            Safe-WriteLine -Top (3 + $row) -Text ("  " + $god[$row]) -Color $color
        }

        $scanPos = $shine % 44
        $scan = ("·" * $scanPos) + "◆" + ("·" * (44 - $scanPos))
        Safe-WriteLine -Top 11 -Text ("  PREMIUM GODPROJEXTH ONLINE  {0}" -f $scan) -Color DarkYellow
        $FrameRef.Value++
        Start-Sleep -Milliseconds 16
    }
}

function Write-IconFile {
    param([string]$Path)

    if ([string]::IsNullOrWhiteSpace($IconPayload)) {
        return
    }

    $folder = Split-Path -Parent $Path

    if (-not (Test-Path -LiteralPath $folder)) {
        New-Item -ItemType Directory -Path $folder -Force | Out-Null
    }

    $bytes = [Convert]::FromBase64String($IconPayload)
    [System.IO.File]::WriteAllBytes($Path, $bytes)
}

function Write-InterfaceFile {
    param([string]$Path)

    $folder = Split-Path -Parent $Path

    if (-not (Test-Path -LiteralPath $folder)) {
        New-Item -ItemType Directory -Path $folder -Force | Out-Null
    }

    $bytes = [Convert]::FromBase64String($InterfacePayload)
    $source = [System.Text.Encoding]::UTF8.GetString($bytes)

    Set-Content -LiteralPath $Path -Value $source -Encoding UTF8 -Force
}

function Find-RuntimeCommand {
    $candidates = New-Object System.Collections.ArrayList

    $py = Get-Command "py.exe" -ErrorAction SilentlyContinue
    if ($py) {
        [void]$candidates.Add(@{ File = $py.Source; PrefixArgs = @("-3") })
    }

    $runtime = Get-Command "python.exe" -ErrorAction SilentlyContinue
    if ($runtime) {
        [void]$candidates.Add(@{ File = $runtime.Source; PrefixArgs = @() })
    }

    try {
        $localRuntime = Get-ChildItem -Path "$env:LOCALAPPDATA\Programs\Python" -Filter "python.exe" -Recurse -ErrorAction SilentlyContinue |
            Sort-Object FullName -Descending |
            Select-Object -First 1

        if ($localRuntime) {
            [void]$candidates.Add(@{ File = $localRuntime.FullName; PrefixArgs = @() })
        }
    }
    catch {
    }

    foreach ($candidate in $candidates) {
        try {
            $versionArgs = @()
            $versionArgs += $candidate.PrefixArgs
            $versionArgs += @("-c", "import sys; print(sys.version_info.major)")
            $output = & $candidate.File @versionArgs 2>$null

            if ($LASTEXITCODE -eq 0 -and ($output -join "").Trim() -eq "3") {
                return $candidate
            }
        }
        catch {
        }
    }

    return $null
}

function Test-UiEngine {
    param($Runtime)

    try {
        $args = @()
        $args += $Runtime.PrefixArgs
        $args += @("-c", "import PySide6; print('OK')")
        $output = & $Runtime.File @args 2>$null

        if ($LASTEXITCODE -eq 0 -and (($output -join "").Trim() -eq "OK")) {
            return $true
        }
    }
    catch {
    }

    return $false
}

function Install-UiEngine {
    param(
        $Runtime,
        [ref]$FrameRef
    )

    Draw-ProtectedLoader -Status "Installing interface engine..." -Percent 58 -Frame $FrameRef.Value
    $FrameRef.Value++

    try {
        $upgradeArgs = @()
        $upgradeArgs += $Runtime.PrefixArgs
        $upgradeArgs += @("-m", "pip", "install", "--user", "--upgrade", "pip")
        $null = & $Runtime.File @upgradeArgs 2>$null
    }
    catch {
    }

    try {
        $installArgs = @()
        $installArgs += $Runtime.PrefixArgs
        $installArgs += @("-m", "pip", "install", "--user", "--upgrade", "PySide6")
        $null = & $Runtime.File @installArgs 2>$null

        if ($LASTEXITCODE -ne 0) {
            return $false
        }

        return $true
    }
    catch {
        return $false
    }
}

function Start-Interface {
    param($Runtime)

    $silentCandidates = New-Object System.Collections.ArrayList

    $pyw = Get-Command "pyw.exe" -ErrorAction SilentlyContinue
    if ($pyw -and $Runtime.PrefixArgs.Count -gt 0) {
        [void]$silentCandidates.Add(@{ File = $pyw.Source; Args = @("-3", "`"$InterfacePath`"") })
    }

    $runtimeW = Get-Command "pythonw.exe" -ErrorAction SilentlyContinue
    if ($runtimeW) {
        [void]$silentCandidates.Add(@{ File = $runtimeW.Source; Args = @("`"$InterfacePath`"") })
    }

    try {
        $localRuntimeW = Get-ChildItem -Path "$env:LOCALAPPDATA\Programs\Python" -Filter "pythonw.exe" -Recurse -ErrorAction SilentlyContinue |
            Sort-Object FullName -Descending |
            Select-Object -First 1

        if ($localRuntimeW) {
            [void]$silentCandidates.Add(@{ File = $localRuntimeW.FullName; Args = @("`"$InterfacePath`"") })
        }
    }
    catch {
    }

    foreach ($launcher in $silentCandidates) {
        try {
            Start-Process -FilePath $launcher.File -ArgumentList $launcher.Args -WindowStyle Hidden | Out-Null
            return $true
        }
        catch {
        }
    }

    try {
        $args = @()
        $args += $Runtime.PrefixArgs
        $args += @("`"$InterfacePath`"")
        Start-Process -FilePath $Runtime.File -ArgumentList $args -WindowStyle Hidden | Out-Null
        return $true
    }
    catch {
        throw "Cannot start GODPROJEXTH interface."
    }
}

try {
    try {
        [Console]::OutputEncoding = [System.Text.Encoding]::UTF8
        [Console]::CursorVisible = $false
        [Console]::Title = "GODPROJEXTH ALPHA"
    }
    catch {
    }

    Draw-GodprojexthHeader

    $frame = 0
    $progress = 0

    $progress = Animate-ToPercent -From $progress -To 16 -Status "Booting GODPROJEXTH..." -FrameRef ([ref]$frame)
    $progress = Animate-ToPercent -From $progress -To 32 -Status "Preparing secure payload..." -FrameRef ([ref]$frame)
    $progress = Animate-ToPercent -From $progress -To 44 -Status "Building isolated interface..." -FrameRef ([ref]$frame)

    New-Item -ItemType Directory -Path $InstallDir -Force | Out-Null
    Write-IconFile -Path $IconPath
    $env:GODPROJEXTH_ICON_PATH = $IconPath
    Write-InterfaceFile -Path $InterfacePath

    $progress = Animate-ToPercent -From $progress -To 54 -Status "Scanning desktop runtime..." -FrameRef ([ref]$frame)

    $runtime = Find-RuntimeCommand

    if ($null -eq $runtime) {
        throw "Required desktop runtime not found."
    }

    if (-not (Test-UiEngine -Runtime $runtime)) {
        [void](Install-UiEngine -Runtime $runtime -FrameRef ([ref]$frame))
    }

    if (Test-UiEngine -Runtime $runtime) {
        $progress = Animate-ToPercent -From 72 -To 86 -Status "Animation engine ready..." -FrameRef ([ref]$frame)
    }
    else {
        $progress = Animate-ToPercent -From 72 -To 86 -Status "Compatibility renderer ready..." -FrameRef ([ref]$frame)
    }

    $progress = Animate-ToPercent -From $progress -To 100 -Status "Launching interface..." -FrameRef ([ref]$frame)

    Show-GodprojexthCredit -FrameRef ([ref]$frame)

    Start-Interface -Runtime $runtime | Out-Null

    Start-Sleep -Milliseconds 900

    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    exit 0
}
catch {
    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    try {
        Add-Content -Path $ErrorLog -Value $_.Exception.Message -Encoding UTF8
    }
    catch {
    }

    Show-ConsoleWindow

    Clear-Host
    Write-Host ""
    Write-Host "  GODPROJEXTH ALPHA ERROR" -ForegroundColor Red
    Write-Host ""
    Write-Host "  $($_.Exception.Message)" -ForegroundColor Red
    Write-Host ""
    Write-Host "  Error log:" -ForegroundColor Yellow
    Write-Host "  $ErrorLog" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "  Press Enter to close..." -ForegroundColor Yellow
    [void][System.Console]::ReadLine()
}
