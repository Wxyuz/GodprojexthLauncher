$ErrorActionPreference = "Stop"
$ProgressPreference = "SilentlyContinue"
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

$AppName = "GODPROJEXTH"
$RepoOwner = "Wxyuz"
$RepoName = "GodprojexthLauncher"
$ExeFileName = "POWERSHELLGODPROJEXTH.exe"

$InstallDir = Join-Path $env:LOCALAPPDATA "GodprojexthPremium"
$ExePath = Join-Path $InstallDir $ExeFileName

$ExpectedSha256 = "C26D4FC1601831B2E0A29C698F9612128DF882FA22680FA4C317A4CE812036A6"

function Initialize-Console {
    try {
        [Console]::OutputEncoding = [System.Text.Encoding]::UTF8
        [Console]::InputEncoding = [System.Text.Encoding]::UTF8
        [Console]::CursorVisible = $false
        $Host.UI.RawUI.WindowTitle = "GODPROJEXTH PREMIUM RUNNER"
    }
    catch {
    }

    try {
        $max = $Host.UI.RawUI.MaxPhysicalWindowSize
        $buffer = $Host.UI.RawUI.BufferSize
        $window = $Host.UI.RawUI.WindowSize

        $targetWidth = [Math]::Min(112, $max.Width)
        $targetHeight = [Math]::Min(34, $max.Height)

        if ($buffer.Width -lt $targetWidth) {
            $Host.UI.RawUI.BufferSize = New-Object System.Management.Automation.Host.Size($targetWidth, [Math]::Max($buffer.Height, 1200))
        }

        if ($window.Width -lt 96) {
            $Host.UI.RawUI.WindowSize = New-Object System.Management.Automation.Host.Size($targetWidth, $targetHeight)
        }
    }
    catch {
    }

    Clear-Host
}

function Get-ConsoleWidthSafe {
    try {
        return [Math]::Max(80, $Host.UI.RawUI.WindowSize.Width)
    }
    catch {
        return 100
    }
}

function Write-Typed {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Text,

        [System.ConsoleColor]$Color = [System.ConsoleColor]::Yellow,

        [int]$Delay = 2,

        [switch]$NoNewLine
    )

    foreach ($char in $Text.ToCharArray()) {
        Write-Host $char -NoNewline -ForegroundColor $Color
        Start-Sleep -Milliseconds $Delay
    }

    if (-not $NoNewLine) {
        Write-Host ""
    }
}

function Write-Centered {
    param(
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::Yellow,
        [int]$Delay = 0
    )

    $width = Get-ConsoleWidthSafe
    $left = [Math]::Max(0, [Math]::Floor(($width - $Text.Length) / 2))
    $line = (" " * $left) + $Text

    if ($Delay -le 0) {
        Write-Host $line -ForegroundColor $Color
    }
    else {
        Write-Typed $line $Color $Delay
    }
}

function Write-Status {
    param(
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::Green,
        [int]$Delay = 2
    )

    Write-Host "   " -NoNewline
    Write-Typed "[GODPROJEXTH] $Text" $Color $Delay
}

function Get-CleanLogo {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Text
    )

    $glyphs = @{
        "A" = @(
            "  /\  ",
            " /  \ ",
            "/----\",
            "|    |",
            "|    |"
        )
        "D" = @(
            "|---\ ",
            "|    |",
            "|    |",
            "|    |",
            "|---/ "
        )
        "E" = @(
            "|----",
            "|    ",
            "|--- ",
            "|    ",
            "|----"
        )
        "G" = @(
            " /---",
            "|    ",
            "|  --",
            "|   |",
            " \--/"
        )
        "H" = @(
            "|    |",
            "|    |",
            "|----|",
            "|    |",
            "|    |"
        )
        "J" = @(
            "  ---|",
            "     |",
            "     |",
            "|    |",
            " \--/ "
        )
        "L" = @(
            "|    ",
            "|    ",
            "|    ",
            "|    ",
            "|----"
        )
        "O" = @(
            " /--\ ",
            "|    |",
            "|    |",
            "|    |",
            " \--/ "
        )
        "P" = @(
            "|---\ ",
            "|    |",
            "|---/ ",
            "|     ",
            "|     "
        )
        "R" = @(
            "|---\ ",
            "|    |",
            "|---/ ",
            "|  \  ",
            "|   \ "
        )
        "T" = @(
            "------",
            "  ||  ",
            "  ||  ",
            "  ||  ",
            "  ||  "
        )
        "X" = @(
            "\    /",
            " \  / ",
            "  ><  ",
            " /  \ ",
            "/    \"
        )
        " " = @(
            "      ",
            "      ",
            "      ",
            "      ",
            "      "
        )
    }

    $rows = @("", "", "", "", "")
    $chars = $Text.ToUpperInvariant().ToCharArray()

    foreach ($char in $chars) {
        $key = [string]$char

        if (-not $glyphs.ContainsKey($key)) {
            $key = " "
        }

        for ($i = 0; $i -lt 5; $i++) {
            $rows[$i] += $glyphs[$key][$i] + " "
        }
    }

    return $rows
}

function Show-CleanLogo {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Text
    )

    $lines = Get-CleanLogo -Text $Text

    foreach ($line in $lines) {
        Write-Centered $line Yellow 0
        Start-Sleep -Milliseconds 14
    }
}

function Show-FrameTop {
    $width = Get-ConsoleWidthSafe
    $inner = [Math]::Min(82, [Math]::Max(56, $width - 20))
    Write-Centered ("╔" + ("═" * $inner) + "╗") DarkYellow
}

function Show-FrameBottom {
    $width = Get-ConsoleWidthSafe
    $inner = [Math]::Min(82, [Math]::Max(56, $width - 20))
    Write-Centered ("╚" + ("═" * $inner) + "╝") DarkYellow
}

function Show-Header {
    Clear-Host
    Write-Host ""

    Show-FrameTop
    Write-Host ""
    Show-CleanLogo "GODPROJEXTH"
    Write-Host ""
    Show-FrameBottom

    Write-Host ""
    Write-Centered "GODPROJEXTH PREMIUM RUNNER" Yellow 2
    Write-Centered "GitHub Release  ->  Verify File  ->  Open Interface" DarkYellow 2
    Write-Host ""
}

function Show-PremiumBar {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Label,

        [int]$Start = 0,

        [int]$End = 100,

        [int]$Delay = 4
    )

    $barWidth = 46
    $frames = @("◜", "◠", "◝", "◞", "◡", "◟")
    $shine = @("◆", "✦", "◇", "✦")

    Write-Host ""
    Write-Centered $Label Yellow 2

    for ($i = $Start; $i -le $End; $i += 2) {
        $filled = [Math]::Floor(($i / 100) * $barWidth)

        if ($filled -lt 0) {
            $filled = 0
        }

        if ($filled -gt $barWidth) {
            $filled = $barWidth
        }

        $empty = $barWidth - $filled
        $spin = $frames[$i % $frames.Count]
        $spark = $shine[$i % $shine.Count]

        $barFull = "█" * $filled
        $barEmpty = "▒" * $empty

        $state = "CONNECTING"

        if ($i -ge 35 -and $i -lt 70) {
            $state = "LOADING"
        }
        elseif ($i -ge 70 -and $i -lt 100) {
            $state = "FINALIZING"
        }
        elseif ($i -ge 100) {
            $state = "SUCCESSFULLY"
        }

        $width = Get-ConsoleWidthSafe
        $visualLength = $barWidth + 31
        $left = [Math]::Max(0, [Math]::Floor(($width - $visualLength) / 2))

        Write-Host "`r" -NoNewline
        Write-Host (" " * $left) -NoNewline
        Write-Host "$spin " -NoNewline -ForegroundColor White
        Write-Host "╞" -NoNewline -ForegroundColor DarkYellow
        Write-Host $barFull -NoNewline -ForegroundColor Yellow
        Write-Host $barEmpty -NoNewline -ForegroundColor DarkGray
        Write-Host "╡ " -NoNewline -ForegroundColor DarkYellow
        Write-Host ("{0,3}%" -f $i) -NoNewline -ForegroundColor White
        Write-Host "  $spark $state" -NoNewline -ForegroundColor Yellow

        Start-Sleep -Milliseconds $Delay
    }

    Write-Host ""
}

function Show-Successfully {
    Write-Host ""
    Write-Centered "SUCCESSFULLY" Green 5
    Start-Sleep -Milliseconds 220
}

function Show-CreditLine {
    param(
        [string]$Name,
        [string]$Value
    )

    $text = ("{0,-8} : {1}" -f $Name, $Value)
    Write-Centered $text Yellow 2
}

function Show-EndCredits {
    Clear-Host
    Write-Host ""

    Show-FrameTop
    Write-Host ""
    Show-CleanLogo "ALPHA"
    Write-Host ""
    Show-CleanLogo "GODPROJEXTH"
    Write-Host ""
    Show-FrameBottom

    Write-Host ""
    Write-Centered "PREMIUM INTERFACE READY" Yellow 2

    Show-PremiumBar -Label "Finalizing premium session" -Start 90 -End 100 -Delay 5
    Show-Successfully

    Write-Host ""
    Write-Centered "╭────────────────────────────────────────────╮" DarkYellow
    Show-CreditLine "WEBSITE" "GODPROJEXTH"
    Show-CreditLine "YOUTUBE" "GODPROJEXTH"
    Show-CreditLine "TIKTOK" "GODPROJEXTH"
    Show-CreditLine "DISCORD" "GODPROJEXTH"
    Write-Centered "╰────────────────────────────────────────────╯" DarkYellow

    Start-Sleep -Milliseconds 220
}

function Ensure-InstallDir {
    if (-not (Test-Path -LiteralPath $InstallDir)) {
        New-Item -ItemType Directory -Path $InstallDir -Force | Out-Null
    }
}

function Get-GitHubExeUrl {
    $releaseApi = "https://api.github.com/repos/$RepoOwner/$RepoName/releases/latest"

    try {
        $headers = @{
            "User-Agent" = "GODPROJEXTH"
            "Accept" = "application/vnd.github+json"
        }

        $release = Invoke-RestMethod -Uri $releaseApi -Headers $headers -Method Get

        if ($null -ne $release -and $null -ne $release.assets) {
            $asset = $release.assets | Where-Object { $_.name -eq $ExeFileName } | Select-Object -First 1

            if ($asset -and -not [string]::IsNullOrWhiteSpace($asset.browser_download_url)) {
                return $asset.browser_download_url
            }
        }
    }
    catch {
    }

    $rawUrl = "https://raw.githubusercontent.com/$RepoOwner/$RepoName/main/$ExeFileName"

    try {
        $null = Invoke-WebRequest -Uri $rawUrl -Method Head -UseBasicParsing
        return $rawUrl
    }
    catch {
    }

    throw "EXE not found on GitHub. Upload $ExeFileName to Latest Release Assets or main branch."
}

function Test-ExistingExe {
    if (-not (Test-Path -LiteralPath $ExePath)) {
        return $false
    }

    try {
        $actual = (Get-FileHash -Algorithm SHA256 -Path $ExePath).Hash.ToUpperInvariant()

        if ($actual -eq $ExpectedSha256.ToUpperInvariant()) {
            return $true
        }

        Remove-Item -LiteralPath $ExePath -Force -ErrorAction SilentlyContinue
        return $false
    }
    catch {
        Remove-Item -LiteralPath $ExePath -Force -ErrorAction SilentlyContinue
        return $false
    }
}

function Download-Exe {
    Ensure-InstallDir

    if (Test-ExistingExe) {
        Write-Status "Verified local package." Green
        return
    }

    Write-Status "Connecting to GitHub release." Green
    Show-PremiumBar -Label "Checking premium package" -Start 1 -End 30 -Delay 4

    $exeUrl = Get-GitHubExeUrl

    Write-Status "Downloading interface package." Yellow
    Show-PremiumBar -Label "Downloading GODPROJEXTH interface" -Start 31 -End 70 -Delay 4

    try {
        Invoke-WebRequest -Uri $exeUrl -OutFile $ExePath -UseBasicParsing
    }
    catch {
        throw "Download failed. Check GitHub Release Asset or repository file."
    }

    if (-not (Test-Path -LiteralPath $ExePath)) {
        throw "Download finished but EXE was not found."
    }

    $info = Get-Item -LiteralPath $ExePath

    if ($info.Length -lt 10240) {
        Remove-Item -LiteralPath $ExePath -Force -ErrorAction SilentlyContinue
        throw "Downloaded EXE looks incomplete."
    }
}

function Verify-Exe {
    Write-Status "Verifying file integrity." Green
    Show-PremiumBar -Label "Verifying SHA256 integrity" -Start 71 -End 88 -Delay 4

    $actual = (Get-FileHash -Algorithm SHA256 -Path $ExePath).Hash.ToUpperInvariant()
    $expected = $ExpectedSha256.ToUpperInvariant()

    if ($actual -ne $expected) {
        Remove-Item -LiteralPath $ExePath -Force -ErrorAction SilentlyContinue
        throw "SHA256 mismatch. File is not the expected GODPROJEXTH EXE."
    }
}

function Open-GuiExe {
    Write-Status "Opening premium interface." Green
    Show-PremiumBar -Label "Opening interface" -Start 89 -End 100 -Delay 4
    Show-Successfully

    Start-Process -FilePath $ExePath -WorkingDirectory $InstallDir
}

function Exit-Runner {
    Start-Sleep -Milliseconds 160

    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    [System.Environment]::Exit(0)
}

try {
    Initialize-Console
    Show-Header

    Download-Exe
    Verify-Exe
    Show-EndCredits
    Open-GuiExe
    Exit-Runner
}
catch {
    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    Write-Host ""
    Write-Host "   [GODPROJEXTH ERROR]" -ForegroundColor Red
    Write-Host "   $($_.Exception.Message)" -ForegroundColor Red
    Write-Host ""
    Write-Host "   Expected EXE name:" -ForegroundColor Yellow
    Write-Host "   $ExeFileName" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "   Install path:" -ForegroundColor Yellow
    Write-Host "   $ExePath" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "   Press Enter to close..." -ForegroundColor Yellow
    [void][System.Console]::ReadLine()
}
