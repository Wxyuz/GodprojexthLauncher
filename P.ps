$ErrorActionPreference = "Stop"
$ProgressPreference = "SilentlyContinue"
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

$RepoOwner   = "Wxyuz"
$RepoName    = "GodprojexthLauncher"
$AssetName   = "Powershell.py"

$InstallRoot = Join-Path $env:LOCALAPPDATA "GodprojexthPremium"
$PayloadPath = Join-Path $InstallRoot "interface.dat"

$RequiredModules = @(
    @{ ImportName = "PySide6"; PackageName = "PySide6" },
    @{ ImportName = "requests"; PackageName = "requests" },
    @{ ImportName = "PIL";     PackageName = "Pillow"  },
    @{ ImportName = "psutil";  PackageName = "psutil"  }
)

function Initialize-Console {
    try {
        [Console]::OutputEncoding = [System.Text.Encoding]::UTF8
        [Console]::InputEncoding  = [System.Text.Encoding]::UTF8
        [Console]::CursorVisible  = $false
    } catch {}

    $Host.UI.RawUI.WindowTitle = "GODPROJEXTH PREMIUM RUNNER"
    Clear-Host
}

function Write-Typed {
    param(
        [Parameter(Mandatory = $true)][string]$Text,
        [ConsoleColor]$Color = [ConsoleColor]::Yellow,
        [int]$Delay = 18,
        [switch]$NoNewLine
    )

    foreach ($ch in $Text.ToCharArray()) {
        Write-Host $ch -NoNewline -ForegroundColor $Color
        Start-Sleep -Milliseconds $Delay
    }

    if (-not $NoNewLine) {
        Write-Host ""
    }
}

function Write-BrandLine {
    param(
        [string]$Text,
        [ConsoleColor]$Color = [ConsoleColor]::Yellow
    )

    Write-Host "   " -NoNewline
    Write-Typed $Text $Color 12
}

function Write-Status {
    param(
        [string]$Text,
        [ConsoleColor]$Color = [ConsoleColor]::Green
    )

    Write-Host "   " -NoNewline
    Write-Typed "[GODPROJEXTH] $Text" $Color 8
}

function Show-Header {
    Clear-Host
    Write-Host ""

    $banner = @(
        "         ______   ______   ______   ______   ______   ______   ______   __   __   ________  __   __ ",
        "        / ____/  / __  /  / __  /  / __  /  / __  /  / __  /  / __  /  \ \ / /  /_  __ _/  \ \ / / ",
        "       / / __   / / / /  / / / /  / /_/ /  / /_/ /  / / / /  / /_/ /    \ V /    / /       \ V /  ",
        "      / /_/ /  / /_/ /  / /_/ /  / ____/  / _, _/  / /_/ /  / _, _/      | |    _/ /_       | |   ",
        "      \____/   \____/   \____/  /_/      /_/ |_|   \____/  /_/ |_|       |_|   /_____/       |_|   "
    )

    foreach ($line in $banner) {
        Write-Host $line -ForegroundColor Yellow
        Start-Sleep -Milliseconds 40
    }

    Write-Host ""
    Write-BrandLine "GODPROJEXTH PREMIUM RUNNER" Yellow
    Write-BrandLine "Secure Load  ->  Premium Connect  ->  Open Interface" DarkYellow
    Write-Host ""
}

function Show-PremiumBar {
    param(
        [Parameter(Mandatory = $true)][string]$Label,
        [int]$Start = 0,
        [int]$End = 100,
        [int]$Delay = 28
    )

    $barWidth = 42
    $spinnerFrames = @("◜","◠","◝","◞","◡","◟")

    Write-Host "   " -NoNewline
    Write-Typed $Label Yellow 10

    for ($i = $Start; $i -le $End; $i++) {
        $filled = [math]::Floor(($i / 100) * $barWidth)
        if ($filled -lt 0) { $filled = 0 }
        if ($filled -gt $barWidth) { $filled = $barWidth }

        $empty = $barWidth - $filled

        $fillText  = ("█" * $filled)
        $emptyText = ("░" * $empty)
        $spinner   = $spinnerFrames[$i % $spinnerFrames.Count]

        Write-Host "`r   " -NoNewline
        Write-Host "$spinner " -NoNewline -ForegroundColor White
        Write-Host "[" -NoNewline -ForegroundColor DarkYellow
        Write-Host $fillText -NoNewline -ForegroundColor Yellow
        Write-Host $emptyText -NoNewline -ForegroundColor DarkGray
        Write-Host "] " -NoNewline -ForegroundColor DarkYellow
        Write-Host ("{0,3}%" -f $i) -NoNewline -ForegroundColor White

        Start-Sleep -Milliseconds $Delay
    }

    Write-Host ""
    Write-Host ""
}

function Show-Credits {
    Clear-Host
    Write-Host ""

    Write-BrandLine "ALPHA GODPROJEXTH" Yellow
    Write-BrandLine "PREMIUM INTERFACE READY..." DarkYellow
    Write-Host ""

    Show-PremiumBar -Label "Finalizing premium interface" -Start 90 -End 100 -Delay 42

    Write-Host "   +----------------------------------------------+" -ForegroundColor DarkYellow
    Write-Host "   | " -NoNewline -ForegroundColor DarkYellow
    Write-Typed "WEBSITE : GODPROJEXTH" Yellow 12
    Write-Host "   | " -NoNewline -ForegroundColor DarkYellow
    Write-Typed "YOUTUBE : GODPROJEXTH" Yellow 12
    Write-Host "   | " -NoNewline -ForegroundColor DarkYellow
    Write-Typed "TIKTOK  : GODPROJEXTH" Yellow 12
    Write-Host "   | " -NoNewline -ForegroundColor DarkYellow
    Write-Typed "DISCORD : GODPROJEXTH" Yellow 12
    Write-Host "   +----------------------------------------------+" -ForegroundColor DarkYellow
    Write-Host ""

    Start-Sleep -Milliseconds 900
}

function Ensure-Folder {
    param([string]$Path)

    if (-not (Test-Path -LiteralPath $Path)) {
        New-Item -ItemType Directory -Path $Path -Force | Out-Null
    }
}

function Find-PythonRuntime {
    $candidates = New-Object System.Collections.ArrayList

    $searchRoots = @(
        "$env:LOCALAPPDATA\Programs\Python",
        "$env:LOCALAPPDATA\Python"
    )

    foreach ($root in $searchRoots) {
        try {
            if (Test-Path -LiteralPath $root) {
                $found = Get-ChildItem -Path $root -Filter "python.exe" -Recurse -ErrorAction SilentlyContinue |
                    Sort-Object FullName -Descending |
                    Select-Object -First 1

                if ($found) {
                    [void]$candidates.Add(@{
                        File = $found.FullName
                        Args = @()
                    })
                }
            }
        } catch {}
    }

    $pyExe = Get-Command "py.exe" -ErrorAction SilentlyContinue
    if ($pyExe -and ($pyExe.Source -notlike "*\WindowsApps\*")) {
        [void]$candidates.Add(@{
            File = $pyExe.Source
            Args = @("-3")
        })
    }

    $pythonExe = Get-Command "python.exe" -ErrorAction SilentlyContinue
    if ($pythonExe -and ($pythonExe.Source -notlike "*\WindowsApps\*")) {
        [void]$candidates.Add(@{
            File = $pythonExe.Source
            Args = @()
        })
    }

    foreach ($candidate in $candidates) {
        try {
            $args = @()
            $args += $candidate.Args
            $args += @("-c", "import sys; print(sys.version_info.major)")

            $output = & $candidate.File @args 2>$null

            if ($LASTEXITCODE -eq 0 -and (($output -join "").Trim() -eq "3")) {
                return $candidate
            }
        } catch {}
    }

    return $null
}

function Get-WindowedRuntime {
    param($Runtime)

    try {
        if ((Split-Path -Leaf $Runtime.File).ToLower() -eq "python.exe") {
            $folder = Split-Path -Parent $Runtime.File
            $pythonw = Join-Path $folder "pythonw.exe"

            if (Test-Path -LiteralPath $pythonw) {
                return @{
                    File = $pythonw
                    Args = @()
                }
            }
        }

        $pyw = Get-Command "pyw.exe" -ErrorAction SilentlyContinue
        if ($pyw -and ($pyw.Source -notlike "*\WindowsApps\*")) {
            return @{
                File = $pyw.Source
                Args = @("-3")
            }
        }
    } catch {}

    return $Runtime
}

function Get-PayloadUrl {
    $releaseApi = "https://api.github.com/repos/$RepoOwner/$RepoName/releases/latest"

    try {
        $headers = @{
            "User-Agent" = "GODPROJEXTH"
            "Accept"     = "application/vnd.github+json"
        }

        $release = Invoke-RestMethod -Uri $releaseApi -Headers $headers -Method Get
        if ($null -ne $release -and $null -ne $release.assets) {
            $asset = $release.assets | Where-Object { $_.name -eq $AssetName } | Select-Object -First 1
            if ($asset -and -not [string]::IsNullOrWhiteSpace($asset.browser_download_url)) {
                return $asset.browser_download_url
            }
        }
    } catch {}

    $rawUrl = "https://raw.githubusercontent.com/$RepoOwner/$RepoName/main/$AssetName"

    try {
        $null = Invoke-WebRequest -Uri $rawUrl -Method Head -UseBasicParsing
        return $rawUrl
    } catch {}

    throw "Cannot find interface payload. Put Powershell.py in Latest Release asset or commit it in the main branch."
}

function Download-Payload {
    Ensure-Folder -Path $InstallRoot

    Write-Status "Engine located successfully." Green
    Show-PremiumBar -Label "Checking secure connection" -Start 1 -End 22 -Delay 36

    $payloadUrl = Get-PayloadUrl

    Write-Status "Premium source verified." Green
    Show-PremiumBar -Label "Downloading protected interface" -Start 23 -End 52 -Delay 32

    try {
        Invoke-WebRequest -Uri $payloadUrl -OutFile $PayloadPath -UseBasicParsing
    } catch {
        throw "Download failed. Check your GitHub release asset or repository file."
    }

    if (-not (Test-Path -LiteralPath $PayloadPath)) {
        throw "Payload was not downloaded successfully."
    }

    $fileInfo = Get-Item -LiteralPath $PayloadPath
    if ($fileInfo.Length -lt 150) {
        Remove-Item -LiteralPath $PayloadPath -Force -ErrorAction SilentlyContinue
        throw "Downloaded payload looks invalid or incomplete."
    }

    Show-PremiumBar -Label "Preparing launch environment" -Start 53 -End 68 -Delay 30
}

function Test-ModuleInstalled {
    param(
        $Runtime,
        [string]$ImportName
    )

    try {
        $args = @()
        $args += $Runtime.Args
        $args += @("-c", "import $ImportName; print('OK')")

        $output = & $Runtime.File @args 2>$null
        if ($LASTEXITCODE -eq 0 -and (($output -join "").Trim() -eq "OK")) {
            return $true
        }
    } catch {}

    return $false
}

function Install-ModulePackage {
    param(
        $Runtime,
        [string]$PackageName
    )

    $args = @()
    $args += $Runtime.Args
    $args += @("-m", "pip", "install", "--user", "--upgrade", $PackageName)

    $result = & $Runtime.File @args 2>&1
    if ($LASTEXITCODE -ne 0) {
        throw "Failed to install required component: $PackageName"
    }
}

function Ensure-Dependencies {
    param($Runtime)

    Write-Status "Checking protected components..." Yellow
    Show-PremiumBar -Label "Loading required components" -Start 69 -End 84 -Delay 28

    foreach ($module in $RequiredModules) {
        if (Test-ModuleInstalled -Runtime $Runtime -ImportName $module.ImportName) {
            continue
        }

        Install-ModulePackage -Runtime $Runtime -PackageName $module.PackageName
    }
}

function Start-Interface {
    param($Runtime)

    Write-Status "Opening premium interface..." Green
    Show-PremiumBar -Label "Opening interface" -Start 85 -End 89 -Delay 34

    $windowed = Get-WindowedRuntime -Runtime $Runtime

    $args = @()
    $args += $windowed.Args
    $args += @("`"$PayloadPath`"")

    Start-Process -FilePath $windowed.File -ArgumentList $args -WorkingDirectory $InstallRoot
}

function Close-Runner {
    Start-Sleep -Milliseconds 600

    try {
        [Console]::CursorVisible = $true
    } catch {}

    [System.Environment]::Exit(0)
}

try {
    Initialize-Console
    Show-Header

    $runtime = Find-PythonRuntime
    if ($null -eq $runtime) {
        throw "Python 3 was not found on this system. Install Python 3 first."
    }

    Download-Payload
    Ensure-Dependencies -Runtime $runtime
    Show-Credits
    Start-Interface -Runtime $runtime
    Close-Runner
}
catch {
    try {
        [Console]::CursorVisible = $true
    } catch {}

    Write-Host ""
    Write-Host "   [GODPROJEXTH ERROR]" -ForegroundColor Red
    Write-Host "   $($_.Exception.Message)" -ForegroundColor Red
    Write-Host ""
    Write-Host "   Press Enter to close..." -ForegroundColor Yellow
    [void][System.Console]::ReadLine()
}
