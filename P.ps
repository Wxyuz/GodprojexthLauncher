function Show-PremiumLoader {
    param(
        [string]$Text,
        [int]$From,
        [int]$To,
        [int]$Delay = 26
    )

    $barWidth = 46

    for ($i = $From; $i -le $To; $i++) {
        $filled = [Math]::Floor(($i / 100) * $barWidth)
        $empty = $barWidth - $filled

        $leftGlow = "▓" * $filled
        $rightDim = "░" * $empty
        $bar = $leftGlow + $rightDim

        $spark = @("✦", "✧", "◆", "◇")[$i % 4]

        Write-Host "`r   $spark $Text [$bar] $i%" -NoNewline -ForegroundColor Yellow
        Start-Sleep -Milliseconds $Delay
    }

    Write-Host ""
}

