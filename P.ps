function Show-PremiumBar {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Label,
        [int]$Start = 0,
        [int]$End = 100,
        [int]$Delay = 4
    )

    $barWidth = 52
    $frames = @("◜", "◠", "◝", "◞", "◡", "◟")
    $shine = @("◆", "✦", "◇", "✦")

    Write-Host ""
    Write-Centered $Label Yellow 2

    for ($i = $Start; $i -le $End; $i += 2) {
        if ($i -gt 100) {
            $i = 100
        }

        $filled = [Math]::Floor(($i / 100) * $barWidth)

        if ($filled -lt 0) {
            $filled = 0
        }

        if ($filled -gt $barWidth) {
            $filled = $barWidth
        }

        $empty = $barWidth - $filled
        $spin = $frames[$i % $frames.Count]
        $spark = $shine[$i % $shine.Count]

        $barFull = "█" * $filled
        $barEmpty = "▓" * $empty

        $state = "CONNECTING"

        if ($i -ge 35 -and $i -lt 70) {
            $state = "DOWNLOADING"
        }
        elseif ($i -ge 70 -and $i -lt 100) {
            $state = "FINALIZING"
        }
        elseif ($i -ge 100) {
            $state = "SUCCESSFULLY"
        }

        $width = Get-ConsoleWidthSafe
        $visualLength = $barWidth + 34
        $left = [Math]::Max(0, [Math]::Floor(($width - $visualLength) / 2))

        Write-Host "`r" -NoNewline
        Write-Host (" " * $left) -NoNewline
        Write-Host "$spin " -NoNewline -ForegroundColor White
        Write-Host "╞" -NoNewline -ForegroundColor DarkYellow
        Write-Host $barFull -NoNewline -ForegroundColor Yellow
        Write-Host $barEmpty -NoNewline -ForegroundColor DarkGray
        Write-Host "╡ " -NoNewline -ForegroundColor DarkYellow
        Write-Host ("{0,3}%" -f $i) -NoNewline -ForegroundColor White
        Write-Host "  $spark $state" -NoNewline -ForegroundColor Yellow

        Start-Sleep -Milliseconds $Delay
    }

    Write-Host ""
}

function Show-Successfully {
    Write-Host ""
    Write-Centered "SUCCESSFULLY" Green 4
    Start-Sleep -Milliseconds 180
}

function Show-CreditLine {
    param(
        [string]$Name,
        [string]$Value
    )

    $text = ("{0,-8} : {1}" -f $Name, $Value)
    Write-Centered $text Yellow 2
}

function Show-EndCredits {
    Show-EndLogo

    Write-Centered "PREMIUM INTERFACE READY" Yellow 2

    Show-PremiumBar -Label "Finalizing premium session" -Start 90 -End 100 -Delay 5
    Show-Successfully

    Write-Host ""
    Write-Centered "╭────────────────────────────────────────────╮" DarkYellow
    Show-CreditLine "WEBSITE" "GODPROJEXTH"
    Show-CreditLine "YOUTUBE" "GODPROJEXTH"
    Show-CreditLine "TIKTOK" "GODPROJEXTH"
    Show-CreditLine "DISCORD" "GODPROJEXTH"
    Write-Centered "╰────────────────────────────────────────────╯" DarkYellow

    Start-Sleep -Milliseconds 220
}

function Ensure-InstallDir {
    if (-not (Test-Path -LiteralPath $InstallDir)) {
        New-Item -ItemType Directory -Path $InstallDir -Force | Out-Null
    }
}

function Invoke-GitHubApi {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Uri
    )

    $headers = @{
        "User-Agent" = "GODPROJEXTH"
        "Accept" = "application/vnd.github+json"
        "Cache-Control" = "no-cache"
    }

    return Invoke-RestMethod -Uri $Uri -Headers $headers -Method Get
}

function Get-LatestRelease {
    $latestUri = "https://api.github.com/repos/$RepoOwner/$RepoName/releases/latest"

    try {
        return Invoke-GitHubApi -Uri $latestUri
    }
    catch {
        throw "Cannot read latest release from GitHub. Make sure you clicked Update release and the repo is public."
    }
}

function Get-AllReleases {
    $releasesUri = "https://api.github.com/repos/$RepoOwner/$RepoName/releases?per_page=30"

    try {
        $releases = Invoke-GitHubApi -Uri $releasesUri

        if ($null -eq $releases) {
            return @()
        }

        return @($releases)
    }
    catch {
        return @()
    }
}

function Get-AssetNamesText {
    param(
        [array]$Assets
    )

    if ($null -eq $Assets -or $Assets.Count -eq 0) {
        return "No uploaded release assets found."
    }

    $names = @()

    foreach ($asset in $Assets) {
        if ($null -ne $asset.name) {
            $names += $asset.name
        }
    }

    if ($names.Count -eq 0) {
        return "No asset names found."
    }

    return ($names -join ", ")
}

function Select-ExeAssetFromAssets {
    param(
        [array]$Assets
    )

    if ($null -eq $Assets -or $Assets.Count -eq 0) {
        return $null
    }

    $exact = $Assets | Where-Object { $_.name -ieq $PreferredExeName } | Select-Object -First 1

    if ($exact -and -not [string]::IsNullOrWhiteSpace($exact.browser_download_url)) {
        return @{
            Url = $exact.browser_download_url
            Name = $exact.name
            Source = "latest-release-exact"
        }
    }

    foreach ($possibleName in $PossibleExeNames) {
        $match = $Assets | Where-Object { $_.name -ieq $possibleName } | Select-Object -First 1

        if ($match -and -not [string]::IsNullOrWhiteSpace($match.browser_download_url)) {
            return @{
                Url = $match.browser_download_url
                Name = $match.name
                Source = "latest-release-known"
            }
        }
    }

    $exeAssets = @($Assets | Where-Object { $_.name -match "\.exe$" })

    if ($exeAssets.Count -eq 1) {
        return @{
            Url = $exeAssets[0].browser_download_url
            Name = $exeAssets[0].name
            Source = "latest-release-single-exe"
        }
    }

    if ($exeAssets.Count -gt 1) {
        $names = Get-AssetNamesText -Assets $exeAssets
        throw "Multiple EXE assets found: $names. Keep only one EXE asset or rename one to $PreferredExeName."
    }

    return $null
}

function Get-GitHubExeInfo {
    $latest = Get-LatestRelease
    $latestAssets = @()

    if ($null -ne $latest.assets) {
        $latestAssets = @($latest.assets)
    }

    $selected = Select-ExeAssetFromAssets -Assets $latestAssets

    if ($null -ne $selected) {
        return $selected
    }

    $latestAssetNames = Get-AssetNamesText -Assets $latestAssets

    $allReleases = Get-AllReleases

    foreach ($release in $allReleases) {
        $assets = @()

        if ($null -ne $release.assets) {
            $assets = @($release.assets)
        }

        $selectedFromRelease = Select-ExeAssetFromAssets -Assets $assets

        if ($null -ne $selectedFromRelease) {
            return @{
                Url = $selectedFromRelease.Url
                Name = $selectedFromRelease.Name
                Source = "other-release"
            }
        }
    }

    foreach ($possibleName in $PossibleExeNames) {
        $rawUrl = "https://raw.githubusercontent.com/$RepoOwner/$RepoName/main/$possibleName"

        try {
            $null = Invoke-WebRequest -Uri $rawUrl -Method Head -UseBasicParsing

            return @{
                Url = $rawUrl
                Name = $possibleName
                Source = "main-branch-raw"
            }
        }
        catch {
        }
    }

    throw "EXE not found. Latest release assets: $latestAssetNames. Upload your GUI EXE to Latest Release Assets and rename it to $PreferredExeName."
}

function Test-ExistingExe {
    if (-not (Test-Path -LiteralPath $ExePath)) {
        return $false
    }

    if ($AlwaysDownloadLatest) {
        return $false
    }

    if ([string]::IsNullOrWhiteSpace($ExpectedSha256)) {
        try {
            $info = Get-Item -LiteralPath $ExePath

            if ($info.Length -gt 10240) {
                return $true
            }

            Remove-Item -LiteralPath $ExePath -Force -ErrorAction SilentlyContinue
            return $false
        }
        catch {
            return $false
        }
    }

    try {
        $actual = (Get-FileHash -Algorithm SHA256 -Path $ExePath).Hash.ToUpperInvariant()

        if ($actual -eq $ExpectedSha256.ToUpperInvariant()) {
            return $true
        }

        Remove-Item -LiteralPath $ExePath -Force -ErrorAction SilentlyContinue
        return $false
    }
    catch {
        Remove-Item -LiteralPath $ExePath -Force -ErrorAction SilentlyContinue
        return $false
    }
}

function Download-Exe {
    Ensure-InstallDir

    if (Test-ExistingExe) {
        Write-Status "Verified local package." Green
        return
    }

    Write-Status "Connecting to GitHub release." Green
    Show-PremiumBar -Label "Checking premium package" -Start 1 -End 28 -Delay 4

    $exeInfo = Get-GitHubExeInfo
    $exeUrl = $exeInfo.Url
    $remoteName = $exeInfo.Name
    $sourceType = $exeInfo.Source

    Write-Status "Found package: $remoteName" Green
    Write-Status "Source: $sourceType" Yellow

    Show-PremiumBar -Label "Downloading GODPROJEXTH interface" -Start 29 -End 70 -Delay 4

    try {
        if (Test-Path -LiteralPath $ExePath) {
            Remove-Item -LiteralPath $ExePath -Force -ErrorAction SilentlyContinue
        }

        Invoke-WebRequest -Uri $exeUrl -OutFile $ExePath -UseBasicParsing
    }
    catch {
        throw "Download failed. Check GitHub Release asset or internet connection."
    }

    if (-not (Test-Path -LiteralPath $ExePath)) {
        throw "Download finished but EXE was not found."
    }

    $info = Get-Item -LiteralPath $ExePath

    if ($info.Length -lt 10240) {
        Remove-Item -LiteralPath $ExePath -Force -ErrorAction SilentlyContinue
        throw "Downloaded EXE looks incomplete."
    }

    try {
        Unblock-File -LiteralPath $ExePath -ErrorAction SilentlyContinue
    }
    catch {
    }
}

function Verify-Exe {
    if ([string]::IsNullOrWhiteSpace($ExpectedSha256)) {
        Write-Status "SHA256 skipped." Yellow
        Show-PremiumBar -Label "Preparing verified package" -Start 71 -End 88 -Delay 4
        return
    }

    Write-Status "Verifying file integrity." Green
    Show-PremiumBar -Label "Verifying SHA256 integrity" -Start 71 -End 88 -Delay 4

    $actual = (Get-FileHash -Algorithm SHA256 -Path $ExePath).Hash.ToUpperInvariant()
    $expected = $ExpectedSha256.ToUpperInvariant()

    if ($actual -ne $expected) {
        Remove-Item -LiteralPath $ExePath -Force -ErrorAction SilentlyContinue
        throw "SHA256 mismatch. File is not the expected GODPROJEXTH EXE."
    }
}

function Open-GuiExe {
    Write-Status "Opening premium interface." Green
    Show-PremiumBar -Label "Opening interface" -Start 89 -End 100 -Delay 4
    Show-Successfully

    Start-Process -FilePath $ExePath -WorkingDirectory $InstallDir
}

function Exit-Runner {
    Start-Sleep -Milliseconds 160

    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    [System.Environment]::Exit(0)
}

try {
    Initialize-Console
    Show-Header

    Download-Exe
    Verify-Exe
    Show-EndCredits
    Open-GuiExe
    Exit-Runner
}
catch {
    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    Write-Host ""
    Write-Host "   [GODPROJEXTH ERROR]" -ForegroundColor Red
    Write-Host "   $($_.Exception.Message)" -ForegroundColor Red
    Write-Host ""
    Write-Host "   Correct fix:" -ForegroundColor Yellow
    Write-Host "   1. Click Update release on GitHub first" -ForegroundColor Yellow
    Write-Host "   2. Make sure this file exists in Assets:" -ForegroundColor Yellow
    Write-Host "      $PreferredExeName" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "   Release page:" -ForegroundColor Yellow
    Write-Host "   https://github.com/$RepoOwner/$RepoName/releases/latest" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "   Install path:" -ForegroundColor Yellow
    Write-Host "   $ExePath" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "   Press Enter to close..." -ForegroundColor Yellow
    [void][System.Console]::ReadLine()
}
