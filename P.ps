function Show-PremiumLoader {
    param(
        [string]$Label,
        [int]$From,
        [int]$To,
        [int]$Delay = 28
    )

    $width = 40
    Write-Host "   " -NoNewline
    Write-Typed $Label Yellow 14

    for ($i = $From; $i -le $To; $i++) {
        $filled = [Math]::Floor(($i / 100) * $width)
        if ($filled -lt 0) { $filled = 0 }
        if ($filled -gt $width) { $filled = $width }

        $empty = $width - $filled

        $spinner = @("◜","◠","◝","◞","◡","◟")[$i % 6]
        $spark   = @("◇","◆","✦","◆")[$i % 4]

        $barFull  = "█" * $filled
        $barEmpty = "░" * $empty

        $state = "CONNECTING"
        if ($i -ge 35 -and $i -lt 70) {
            $state = "LOADING"
        }
        elseif ($i -ge 70) {
            $state = "FINALIZING"
        }

        Write-Host "`r   " -NoNewline
        Write-Host "$spinner " -NoNewline -ForegroundColor White
        Write-Host "╞" -NoNewline -ForegroundColor DarkYellow
        Write-Host $barFull -NoNewline -ForegroundColor Yellow
        Write-Host $barEmpty -NoNewline -ForegroundColor DarkGray
        Write-Host "╡ " -NoNewline -ForegroundColor DarkYellow
        Write-Host ("{0,3}%" -f $i) -NoNewline -ForegroundColor White
        Write-Host "  $spark $state" -NoNewline -ForegroundColor Yellow

        Start-Sleep -Milliseconds $Delay
    }

    Write-Host ""
    Write-Host ""
}

function Show-Credits {
    Clear-Host
    Write-Host ""
    Show-AlphaLogo
    Write-Host ""

    Write-Section "PREMIUM INTERFACE READY..." Yellow
    Show-PremiumLoader "Finalizing premium session" 90 100 40

    Write-Host "      ╭────────────────────────────────────────────╮" -ForegroundColor DarkYellow
    Write-Host "      │  WEBSITE : GODPROJEXTH                    │" -ForegroundColor Yellow
    Start-Sleep -Milliseconds 180
    Write-Host "      │  YOUTUBE : GODPROJEXTH                    │" -ForegroundColor Yellow
    Start-Sleep -Milliseconds 180
    Write-Host "      │  TIKTOK  : GODPROJEXTH                    │" -ForegroundColor Yellow
    Start-Sleep -Milliseconds 180
    Write-Host "      │  DISCORD : GODPROJEXTH                    │" -ForegroundColor Yellow
    Write-Host "      ╰────────────────────────────────────────────╯" -ForegroundColor DarkYellow
    Write-Host ""
}

function Open-LocalGui {
    Add-Type -AssemblyName System.Windows.Forms

    $dialog = New-Object System.Windows.Forms.OpenFileDialog
    $dialog.Title = "Select your GUI file"
    $dialog.Filter = "Python or EXE|*.py;*.exe|All files|*.*"
    $dialog.Multiselect = $false

    $result = $dialog.ShowDialog()

    if ($result -ne [System.Windows.Forms.DialogResult]::OK) {
        Write-Section "No file selected. Closing..." Yellow
        return
    }

    $file = $dialog.FileName
    $ext = [System.IO.Path]::GetExtension($file).ToLowerInvariant()

    if ($ext -eq ".exe") {
        Start-Process -FilePath $file
        return
    }

    if ($ext -eq ".py") {
        $python = Get-Command pythonw.exe -ErrorAction SilentlyContinue
        if (-not $python) {
            $python = Get-Command python.exe -ErrorAction SilentlyContinue
        }

        if (-not $python) {
            throw "Python was not found."
        }

        Start-Process -FilePath $python.Source -ArgumentList "`"$file`""
        return
    }

    Start-Process -FilePath $file
}

try {
    Clear-Host
    Show-GodprojexthLogo
    Write-Host ""
    Write-Section "GODPROJEXTH PREMIUM RUNNER" Yellow
    Write-Section "Secure Load  ->  Premium Check  ->  Open Interface" DarkYellow
    Write-Host ""

    Show-PremiumLoader "Connecting premium system" 1 25 34
    Show-PremiumLoader "Preparing visual interface" 26 55 30
    Show-PremiumLoader "Checking local environment" 56 80 28
    Show-PremiumLoader "Opening user interface" 81 89 32

    Show-Credits
    Open-LocalGui

    Start-Sleep -Milliseconds 700
}
catch {
    try { [Console]::CursorVisible = $true } catch {}

    Write-Host ""
    Write-Host "   [GODPROJEXTH ERROR]" -ForegroundColor Red
    Write-Host "   $($_.Exception.Message)" -ForegroundColor Red
    Write-Host ""
    Write-Host "   Press Enter to close..." -ForegroundColor Yellow
    [void][System.Console]::ReadLine()
}
finally {
    try { [Console]::CursorVisible = $true } catch {}
}
