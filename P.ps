$ErrorActionPreference = "Stop"
$ProgressPreference = "SilentlyContinue"

try {
    [Console]::OutputEncoding = [System.Text.Encoding]::UTF8
    [Console]::InputEncoding = [System.Text.Encoding]::UTF8
    [Console]::CursorVisible = $false
    $Host.UI.RawUI.WindowTitle = "GODPROJEXTH PREMIUM RUNNER"
}
catch {
}

function Get-ConsoleWidthSafe {
    try {
        return [Math]::Max(80, $Host.UI.RawUI.WindowSize.Width)
    }
    catch {
        return 100
    }
}

function Write-Typed {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Text,

        [System.ConsoleColor]$Color = [System.ConsoleColor]::Yellow,

        [int]$Delay = 4,

        [switch]$NoNewLine
    )

    foreach ($char in $Text.ToCharArray()) {
        Write-Host $char -NoNewline -ForegroundColor $Color
        Start-Sleep -Milliseconds $Delay
    }

    if (-not $NoNewLine) {
        Write-Host ""
    }
}

function Write-Centered {
    param(
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::Yellow,
        [int]$Delay = 0
    )

    $width = Get-ConsoleWidthSafe
    $left = [Math]::Max(0, [Math]::Floor(($width - $Text.Length) / 2))
    $line = (" " * $left) + $Text

    if ($Delay -le 0) {
        Write-Host $line -ForegroundColor $Color
    }
    else {
        Write-Typed $line $Color $Delay
    }
}

function Write-Status {
    param(
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::Green
    )

    Write-Host "   " -NoNewline
    Write-Typed "[GODPROJEXTH] $Text" $Color 4
}

function Get-ThinLogo {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Text
    )

    $glyphs = @{
        "A" = @(
            "  ╱╲  ",
            " ╱  ╲ ",
            "╱────╲",
            "│    │",
            "│    │"
        )
        "D" = @(
            "╭───╮ ",
            "│   │ ",
            "│   │ ",
            "│   │ ",
            "╰───╯ "
        )
        "E" = @(
            "╭────",
            "│    ",
            "├─── ",
            "│    ",
            "╰────"
        )
        "G" = @(
            "╭────",
            "│    ",
            "│  ─╮",
            "│   │",
            "╰───╯"
        )
        "H" = @(
            "│   │",
            "│   │",
            "├───┤",
            "│   │",
            "│   │"
        )
        "J" = @(
            " ───╮",
            "    │",
            "    │",
            "│   │",
            "╰───╯"
        )
        "L" = @(
            "│    ",
            "│    ",
            "│    ",
            "│    ",
            "╰────"
        )
        "O" = @(
            "╭───╮",
            "│   │",
            "│   │",
            "│   │",
            "╰───╯"
        )
        "P" = @(
            "╭───╮",
            "│   │",
            "├───╯",
            "│    ",
            "│    "
        )
        "R" = @(
            "╭───╮",
            "│   │",
            "├───╯",
            "│ ╲  ",
            "│  ╲ "
        )
        "T" = @(
            "─────",
            "  │  ",
            "  │  ",
            "  │  ",
            "  │  "
        )
        "X" = @(
            "╲   ╱",
            " ╲ ╱ ",
            "  ╳  ",
            " ╱ ╲ ",
            "╱   ╲"
        )
        " " = @(
            "     ",
            "     ",
            "     ",
            "     ",
            "     "
        )
    }

    $rows = @("", "", "", "", "")
    $chars = $Text.ToUpperInvariant().ToCharArray()

    foreach ($char in $chars) {
        $key = [string]$char

        if (-not $glyphs.ContainsKey($key)) {
            $key = " "
        }

        for ($i = 0; $i -lt 5; $i++) {
            $rows[$i] += $glyphs[$key][$i] + " "
        }
    }

    return $rows
}

function Show-ThinLogo {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Text
    )

    $lines = Get-ThinLogo -Text $Text

    foreach ($line in $lines) {
        Write-Centered $line Yellow 1
        Start-Sleep -Milliseconds 15
    }
}

function Show-FrameTop {
    $width = Get-ConsoleWidthSafe
    $inner = [Math]::Min(84, [Math]::Max(54, $width - 18))
    Write-Centered ("╭" + ("─" * $inner) + "╮") DarkYellow
}

function Show-FrameBottom {
    $width = Get-ConsoleWidthSafe
    $inner = [Math]::Min(84, [Math]::Max(54, $width - 18))
    Write-Centered ("╰" + ("─" * $inner) + "╯") DarkYellow
}

function Show-Header {
    Clear-Host
    Write-Host ""
    Show-FrameTop
    Write-Host ""
    Show-ThinLogo "GODPROJEXTH"
    Write-Host ""
    Show-FrameBottom
    Write-Host ""
    Write-Centered "GODPROJEXTH PREMIUM RUNNER" Yellow 4
    Write-Centered "Premium Load  ->  Secure Check  ->  Interface Ready" DarkYellow 3
    Write-Host ""
}

function Show-PremiumBar {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Label,

        [int]$Start = 0,

        [int]$End = 100,

        [int]$Delay = 7
    )

    $barWidth = 42
    $frames = @("◜", "◠", "◝", "◞", "◡", "◟")
    $shine = @("·", "✦", "◆", "✦")

    Write-Host ""
    Write-Centered $Label Yellow 3

    for ($i = $Start; $i -le $End; $i++) {
        $filled = [Math]::Floor(($i / 100) * $barWidth)

        if ($filled -lt 0) {
            $filled = 0
        }

        if ($filled -gt $barWidth) {
            $filled = $barWidth
        }

        $empty = $barWidth - $filled
        $spin = $frames[$i % $frames.Count]
        $spark = $shine[$i % $shine.Count]

        $barFull = "━" * $filled
        $barEmpty = "─" * $empty

        $state = "CONNECTING"

        if ($i -ge 35 -and $i -lt 70) {
            $state = "LOADING"
        }
        elseif ($i -ge 70) {
            $state = "READY"
        }

        $width = Get-ConsoleWidthSafe
        $visualLength = $barWidth + 27
        $left = [Math]::Max(0, [Math]::Floor(($width - $visualLength) / 2))

        Write-Host "`r" -NoNewline
        Write-Host (" " * $left) -NoNewline
        Write-Host "$spin " -NoNewline -ForegroundColor White
        Write-Host "╞" -NoNewline -ForegroundColor DarkYellow
        Write-Host $barFull -NoNewline -ForegroundColor Yellow
        Write-Host $barEmpty -NoNewline -ForegroundColor DarkGray
        Write-Host "╡ " -NoNewline -ForegroundColor DarkYellow
        Write-Host ("{0,3}%" -f $i) -NoNewline -ForegroundColor White
        Write-Host "  $spark $state" -NoNewline -ForegroundColor Yellow

        Start-Sleep -Milliseconds $Delay
    }

    Write-Host ""
}

function Show-CreditLine {
    param(
        [string]$Name,
        [string]$Value
    )

    $text = ("{0,-8} : {1}" -f $Name, $Value)
    Write-Centered $text Yellow 4
}

function Show-EndCredits {
    Clear-Host
    Write-Host ""

    Show-FrameTop
    Write-Host ""
    Show-ThinLogo "ALPHA"
    Write-Host ""
    Show-ThinLogo "GODPROJEXTH"
    Write-Host ""
    Show-FrameBottom

    Write-Host ""
    Write-Centered "PREMIUM INTERFACE READY" Yellow 4

    Show-PremiumBar -Label "Finalizing premium session" -Start 90 -End 100 -Delay 9

    Write-Host ""
    Write-Centered "╭────────────────────────────────────────────╮" DarkYellow
    Show-CreditLine "WEBSITE" "GODPROJEXTH"
    Show-CreditLine "YOUTUBE" "GODPROJEXTH"
    Show-CreditLine "TIKTOK" "GODPROJEXTH"
    Show-CreditLine "DISCORD" "GODPROJEXTH"
    Write-Centered "╰────────────────────────────────────────────╯" DarkYellow

    Start-Sleep -Milliseconds 450
}

try {
    Show-Header

    Write-Status "Preparing premium session." Green
    Show-PremiumBar -Label "Checking premium environment" -Start 1 -End 25 -Delay 7

    Write-Status "Loading visual interface." Green
    Show-PremiumBar -Label "Loading premium visuals" -Start 26 -End 55 -Delay 6

    Write-Status "Checking local session." Yellow
    Show-PremiumBar -Label "Verifying session state" -Start 56 -End 82 -Delay 6

    Write-Status "Finishing loader." Green
    Show-PremiumBar -Label "Opening final stage" -Start 83 -End 89 -Delay 7

    Show-EndCredits

    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    [System.Environment]::Exit(0)
}
catch {
    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    Write-Host ""
    Write-Host "   [GODPROJEXTH ERROR]" -ForegroundColor Red
    Write-Host "   $($_.Exception.Message)" -ForegroundColor Red
    Write-Host ""
    Write-Host "   Press Enter to close..." -ForegroundColor Yellow
    [void][System.Console]::ReadLine()
}
