    Write-Centered "╔════════════════════════════════════════════════════════════════════════════╗" DarkYellow
    Write-Centered "║                                                                            ║" DarkYellow
    Write-Centered "║                      A L P H A   G O D P R O J E X T H                     ║" Yellow
    Write-Centered "║                                                                            ║" DarkYellow
    Write-Centered "║                   █████  ██      ██████  ██  ██  █████                     ║" Yellow
    Write-Centered "║                   ██ ██  ██      ██  ██  ██  ██  ██ ██                     ║" Yellow
    Write-Centered "║                   █████  ██      ██████  ██████  █████                     ║" Yellow
    Write-Centered "║                   ██ ██  ██      ██      ██  ██  ██ ██                     ║" Yellow
    Write-Centered "║                   ██ ██  ██████  ██      ██  ██  ██ ██                     ║" Yellow
    Write-Centered "║                                                                            ║" DarkYellow
    Write-Centered "║                         G O D P R O J E X T H                              ║" Yellow
