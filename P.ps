$ErrorActionPreference = "Stop"
$ProgressPreference = "SilentlyContinue"

$AppName = "POWERSHELLGODPROJEXTH"
$ScriptDir = Split-Path -Parent $MyInvocation.MyCommand.Path
$ExePath = Join-Path $ScriptDir "POWERSHELLGODPROJEXTH.exe"
$ExpectedSha256 = "C26D4FC1601831B2E0A29C698F9612128DF882FA22680FA4C317A4CE812036A6"

function Write-Status {
    param(
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::Yellow
    )

    Write-Host "[GODPROJEXTH] $Text" -ForegroundColor $Color
}

try {
    Clear-Host
    Write-Host ""
    Write-Host "  GODPROJEXTH EXE LAUNCHER" -ForegroundColor Yellow
    Write-Host ""

    if (-not (Test-Path -LiteralPath $ExePath)) {
        throw "Cannot find POWERSHELLGODPROJEXTH.exe beside P.ps"
    }

    Write-Status "Checking SHA256..."
    $ActualSha256 = (Get-FileHash -Algorithm SHA256 -Path $ExePath).Hash.ToUpperInvariant()

    if ($ActualSha256 -ne $ExpectedSha256.ToUpperInvariant()) {
        throw "SHA256 mismatch. File changed or corrupted."
    }

    Write-Status "Launching $AppName..." Green
    Start-Process -FilePath $ExePath -WorkingDirectory $ScriptDir

    Write-Host ""
    Write-Status "Done." Green
}
catch {
    Write-Host ""
    Write-Host "[GODPROJEXTH ERROR]" -ForegroundColor Red
    Write-Host $_.Exception.Message -ForegroundColor Red
    Write-Host ""
    Write-Host "Press Enter to close..." -ForegroundColor Yellow
    [void][System.Console]::ReadLine()
}
