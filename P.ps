$ErrorActionPreference = "Stop"
$ProgressPreference = "SilentlyContinue"

$AppName = "GODPROJEXTH"
$InstallDir = Join-Path $env:LOCALAPPDATA "GodprojexthLauncher"
$PayloadPath = Join-Path $InstallDir "GODPROJEXTH_Interface"

$RepoOwner = "Wxyuz"
$RepoName = "GodprojexthLauncher"
$AssetName = "Powershell.py"

$RequiredModules = @(
    @{ ImportName = "PySide6"; PackageName = "PySide6" },
    @{ ImportName = "requests"; PackageName = "requests" },
    @{ ImportName = "PIL"; PackageName = "Pillow" },
    @{ ImportName = "psutil"; PackageName = "psutil" }
)

function Set-ConsoleLook {
    try {
        [Console]::OutputEncoding = [System.Text.Encoding]::UTF8
        [Console]::InputEncoding = [System.Text.Encoding]::UTF8
        [Console]::CursorVisible = $false
        [Console]::Title = "GODPROJEXTH PREMIUM RUNNER"
    }
    catch {
    }
}

function Write-SlowText {
    param(
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::Yellow,
        [int]$Delay = 28
    )

    foreach ($char in $Text.ToCharArray()) {
        Write-Host $char -NoNewline -ForegroundColor $Color
        Start-Sleep -Milliseconds $Delay
    }

    Write-Host ""
}

function Write-GodStatus {
    param(
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::Yellow,
        [int]$Delay = 18
    )

    Write-Host "   " -NoNewline
    Write-SlowText "[GODPROJEXTH] $Text" $Color $Delay
}

function Show-GodHeader {
    Clear-Host
    Write-Host ""

    $logo = @(
"   ####    ###   ####   ####   #####   ###    ###  #####  #   #  #####  #   #",
"  #       #   #  #   #  #   #  #   #  #   #    #   #       # #     #    #   #",
"  #  ##   #   #  #   #  ####   #####  #   #    #   ####     #      #    #####",
"  #   #   #   #  #   #  #      #  #   #   #    #   #       # #     #    #   #",
"   ####    ###   ####   #      #   #   ###   ###   #####  #   #    #    #   #"
    )

    foreach ($line in $logo) {
        Write-SlowText $line Yellow 3
        Start-Sleep -Milliseconds 35
    }

    Write-Host ""
    Write-SlowText "   GODPROJEXTH PREMIUM RUNNER" Yellow 36
    Write-SlowText "   Secure Connect  ->  Premium Load  ->  Open Interface" DarkYellow 22
    Write-Host ""
}

function Show-PremiumLoader {
    param(
        [string]$Text,
        [int]$From,
        [int]$To,
        [int]$Delay = 34
    )

    $barWidth = 44

    Write-Host "   " -NoNewline
    Write-SlowText $Text Yellow 18

    for ($i = $From; $i -le $To; $i++) {
        $filled = [Math]::Floor(($i / 100) * $barWidth)
        $empty = $barWidth - $filled

        if ($filled -lt 0) {
            $filled = 0
        }

        if ($filled -gt $barWidth) {
            $filled = $barWidth
        }

        $mainFill = "█" * $filled
        $emptyFill = "░" * $empty
        $spinner = @("◐", "◓", "◑", "◒")[$i % 4]

        Write-Host "`r   " -NoNewline
        Write-Host $spinner -NoNewline -ForegroundColor White
        Write-Host "  [" -NoNewline -ForegroundColor DarkYellow
        Write-Host $mainFill -NoNewline -ForegroundColor Yellow
        Write-Host $emptyFill -NoNewline -ForegroundColor DarkGray
        Write-Host ("] {0,3}%  " -f $i) -NoNewline -ForegroundColor Yellow

        if ($i -lt 35) {
            Write-Host "CONNECTING" -NoNewline -ForegroundColor DarkYellow
        }
        elseif ($i -lt 70) {
            Write-Host "LOADING" -NoNewline -ForegroundColor Yellow
        }
        else {
            Write-Host "FINALIZING" -NoNewline -ForegroundColor Green
        }

        Start-Sleep -Milliseconds $Delay
    }

    Write-Host ""
    Write-Host ""
}

function Show-CreditLine {
    param(
        [string]$Left,
        [string]$Right,
        [System.ConsoleColor]$LeftColor = [System.ConsoleColor]::DarkYellow,
        [System.ConsoleColor]$RightColor = [System.ConsoleColor]::Yellow
    )

    Write-Host "   |  " -NoNewline -ForegroundColor DarkYellow
    Write-SlowText ($Left.PadRight(10) + " : ") $LeftColor 18 -NoNewLine
    Write-SlowText $Right $RightColor 22
}

function Write-SlowText {
    param(
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::Yellow,
        [int]$Delay = 28,
        [switch]$NoNewLine
    )

    foreach ($char in $Text.ToCharArray()) {
        Write-Host $char -NoNewline -ForegroundColor $Color
        Start-Sleep -Milliseconds $Delay
    }

    if (-not $NoNewLine) {
        Write-Host ""
    }
}

function Show-AlphaCredit {
    Clear-Host
    Write-Host ""

    $title = @(
"      AAAAA   LL       PPPPPP   HH   HH    AAAAA",
"     AA   AA  LL       PP   PP  HH   HH   AA   AA",
"     AAAAAAA  LL       PPPPPP   HHHHHHH   AAAAAAA",
"     AA   AA  LL       PP       HH   HH   AA   AA",
"     AA   AA  LLLLLLL  PP       HH   HH   AA   AA"
    )

    $god = @(
"   ####    ###   ####   ####   #####   ###    ###  #####  #   #  #####  #   #",
"  #       #   #  #   #  #   #  #   #  #   #    #   #       # #     #    #   #",
"  #  ##   #   #  #   #  ####   #####  #   #    #   ####     #      #    #####",
"  #   #   #   #  #   #  #      #  #   #   #    #   #       # #     #    #   #",
"   ####    ###   ####   #      #   #   ###   ###   #####  #   #    #    #   #"
    )

    Write-SlowText "   INITIALIZING PREMIUM CREDIT..." Yellow 34
    Start-Sleep -Milliseconds 250
    Write-Host ""

    foreach ($line in $title) {
        Write-SlowText $line Yellow 4
        Start-Sleep -Milliseconds 70
    }

    Write-Host ""

    foreach ($line in $god) {
        Write-SlowText $line Yellow 3
        Start-Sleep -Milliseconds 55
    }

    Write-Host ""
    Write-SlowText "   ALPHA GODPROJEXTH" White 42
    Write-SlowText "   PREMIUM INTERFACE READY..." Yellow 28
    Write-Host ""

    Write-Host "   +--------------------------------------------------+" -ForegroundColor DarkYellow
    Show-CreditLine "WEBSITE" "GODPROJEXTH"
    Show-CreditLine "YOUTUBE" "GODPROJEXTH"
    Show-CreditLine "TIKTOK" "GODPROJEXTH"
    Show-CreditLine "DISCORD" "GODPROJEXTH"
    Write-Host "   +--------------------------------------------------+" -ForegroundColor DarkYellow
    Write-Host ""

    Show-PremiumLoader -Text "Finalizing premium launch" -From 88 -To 100 -Delay 42
    Start-Sleep -Milliseconds 450
}

function Ensure-Folder {
    param([string]$Path)

    if (-not (Test-Path -LiteralPath $Path)) {
        New-Item -ItemType Directory -Path $Path -Force | Out-Null
    }
}

function Get-LatestReleaseAssetUrl {
    $apiUrl = "https://api.github.com/repos/$RepoOwner/$RepoName/releases/latest"

    try {
        $headers = @{
            "User-Agent" = "GODPROJEXTH"
            "Accept" = "application/vnd.github+json"
        }

        $release = Invoke-RestMethod -Uri $apiUrl -Headers $headers -Method Get

        if ($null -eq $release) {
            throw "Empty release response."
        }

        if ($null -eq $release.assets) {
            throw "Release has no assets."
        }

        $asset = $release.assets | Where-Object { $_.name -eq $AssetName } | Select-Object -First 1

        if ($null -eq $asset) {
            throw "Target asset not found."
        }

        if ([string]::IsNullOrWhiteSpace($asset.browser_download_url)) {
            throw "Asset download URL is empty."
        }

        return $asset.browser_download_url
    }
    catch {
        throw "Cannot find release asset. Upload the interface file to GitHub Release Assets and click Update release."
    }
}

function Find-PythonRuntime {
    $candidates = New-Object System.Collections.ArrayList

    $searchRoots = @(
        "$env:LOCALAPPDATA\Programs\Python",
        "$env:LOCALAPPDATA\Python"
    )

    foreach ($root in $searchRoots) {
        try {
            if (Test-Path -LiteralPath $root) {
                $localPython = Get-ChildItem -Path $root -Filter "python.exe" -Recurse -ErrorAction SilentlyContinue |
                    Sort-Object FullName -Descending |
                    Select-Object -First 1

                if ($localPython) {
                    [void]$candidates.Add(@{
                        File = $localPython.FullName
                        Args = @()
                    })
                }
            }
        }
        catch {
        }
    }

    $py = Get-Command "py.exe" -ErrorAction SilentlyContinue
    if ($py -and ($py.Source -notlike "*\WindowsApps\*")) {
        [void]$candidates.Add(@{
            File = $py.Source
            Args = @("-3")
        })
    }

    $python = Get-Command "python.exe" -ErrorAction SilentlyContinue
    if ($python -and ($python.Source -notlike "*\WindowsApps\*")) {
        [void]$candidates.Add(@{
            File = $python.Source
            Args = @()
        })
    }

    foreach ($candidate in $candidates) {
        try {
            $checkArgs = @()
            $checkArgs += $candidate.Args
            $checkArgs += @("-c", "import sys; print(sys.version_info.major)")

            $output = & $candidate.File @checkArgs 2>$null

            if ($LASTEXITCODE -eq 0 -and (($output -join "").Trim() -eq "3")) {
                return $candidate
            }
        }
        catch {
        }
    }

    return $null
}

function Get-WindowedRuntime {
    param($Runtime)

    try {
        if ((Split-Path -Leaf $Runtime.File).ToLower() -eq "python.exe") {
            $dir = Split-Path -Parent $Runtime.File
            $pythonw = Join-Path $dir "pythonw.exe"

            if (Test-Path -LiteralPath $pythonw) {
                return @{
                    File = $pythonw
                    Args = @()
                }
            }
        }

        $pyw = Get-Command "pyw.exe" -ErrorAction SilentlyContinue

        if ($pyw -and ($pyw.Source -notlike "*\WindowsApps\*")) {
            return @{
                File = $pyw.Source
                Args = @("-3")
            }
        }
    }
    catch {
    }

    return $Runtime
}

function Download-Payload {
    Ensure-Folder -Path $InstallDir

    Write-GodStatus "Connecting to premium server..." Yellow 24
    Show-PremiumLoader -Text "Secure premium connection" -From 1 -To 18 -Delay 40

    $downloadUrl = Get-LatestReleaseAssetUrl

    Write-GodStatus "Connection authenticated." Green 22
    Show-PremiumLoader -Text "Preparing premium interface" -From 19 -To 38 -Delay 38

    try {
        Invoke-WebRequest -Uri $downloadUrl -OutFile $PayloadPath -UseBasicParsing
    }
    catch {
        throw "Download failed. Check GitHub Release asset and click Update release."
    }

    Show-PremiumLoader -Text "Loading protected interface" -From 39 -To 60 -Delay 36

    if (-not (Test-Path -LiteralPath $PayloadPath)) {
        throw "Download finished but payload was not found."
    }

    $fileSize = (Get-Item -LiteralPath $PayloadPath).Length

    if ($fileSize -lt 100) {
        Remove-Item -LiteralPath $PayloadPath -Force -ErrorAction SilentlyContinue
        throw "Downloaded payload is too small. Release asset may be incorrect."
    }
}

function Test-PythonModule {
    param(
        $Runtime,
        [string]$ImportName
    )

    try {
        $args = @()
        $args += $Runtime.Args
        $args += @("-c", "import $ImportName; print('OK')")

        $output = & $Runtime.File @args 2>$null

        if ($LASTEXITCODE -eq 0 -and (($output -join "").Trim() -eq "OK")) {
            return $true
        }
    }
    catch {
    }

    return $false
}

function Install-PythonPackage {
    param(
        $Runtime,
        [string]$PackageName
    )

    $args = @()
    $args += $Runtime.Args
    $args += @("-m", "pip", "install", "--user", "--upgrade", $PackageName)

    $installOutput = & $Runtime.File @args 2>&1

    if ($LASTEXITCODE -ne 0) {
        throw "Failed to install package: $PackageName"
    }
}

function Install-GuiDependencies {
    param($Runtime)

    Write-GodStatus "Checking premium engine..." Yellow 22
    Show-PremiumLoader -Text "Checking engine components" -From 61 -To 76 -Delay 34

    foreach ($module in $RequiredModules) {
        $importName = $module.ImportName
        $packageName = $module.PackageName

        if (Test-PythonModule -Runtime $Runtime -ImportName $importName) {
            Write-GodStatus "$packageName ready." Green 9
            continue
        }

        Write-GodStatus "Installing engine component..." Yellow 12
        Install-PythonPackage -Runtime $Runtime -PackageName $packageName
    }
}

function Start-Interface {
    param($Runtime)

    Write-GodStatus "Opening premium interface..." Yellow 24
    Show-PremiumLoader -Text "Opening interface" -From 77 -To 87 -Delay 34

    $windowed = Get-WindowedRuntime -Runtime $Runtime

    $args = @()
    $args += $windowed.Args
    $args += @("`"$PayloadPath`"")

    Start-Process -FilePath $windowed.File -ArgumentList $args -WorkingDirectory $InstallDir
}

function Close-RunnerWindow {
    Start-Sleep -Milliseconds 700

    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    Stop-Process -Id $PID -Force
}

try {
    Set-ConsoleLook
    Show-GodHeader

    $runtime = Find-PythonRuntime

    if ($null -eq $runtime) {
        throw "Python 3 not found. Install Python 3 first. Avoid Microsoft Store alias."
    }

    Write-GodStatus "Premium engine found." Green 22

    Download-Payload
    Install-GuiDependencies -Runtime $runtime
    Show-AlphaCredit
    Start-Interface -Runtime $runtime

    Close-RunnerWindow
}
catch {
    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    Write-Host ""
    Write-Host "   [GODPROJEXTH ERROR]" -ForegroundColor Red
    Write-Host "   $($_.Exception.Message)" -ForegroundColor Red
    Write-Host ""
    Write-Host "   Press Enter to close..." -ForegroundColor Yellow
    [void][System.Console]::ReadLine()
}
