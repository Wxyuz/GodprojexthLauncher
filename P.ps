$ErrorActionPreference = "Stop"
$ProgressPreference = "SilentlyContinue"

$AppName = "GODPROJEXTH"
$InstallDir = Join-Path $env:LOCALAPPDATA "GodprojexthLauncher"
$PyPath = Join-Path $InstallDir "Powershell.py"

# ไฟล์ .py ของคุณชื่อ Powershell.py
$PyUrl = "https://raw.githubusercontent.com/Wxyuz/GodprojexthLauncher/main/Powershell.py"

$RequiredModules = @(
    @{ ImportName = "PySide6"; PackageName = "PySide6" },
    @{ ImportName = "requests"; PackageName = "requests" },
    @{ ImportName = "PIL"; PackageName = "Pillow" }
)

function Show-Header {
    Clear-Host
    Write-Host ""
    Write-Host "   ██████╗  ██████╗ ██████╗ ██████╗  ██████╗      ██╗███████╗██╗  ██╗████████╗██╗  ██╗" -ForegroundColor Yellow
    Write-Host "  ██╔════╝ ██╔═══██╗██╔══██╗██╔══██╗██╔═══██╗     ██║██╔════╝╚██╗██╔╝╚══██╔══╝██║  ██║" -ForegroundColor Yellow
    Write-Host "  ██║  ███╗██║   ██║██║  ██║██████╔╝██║   ██║     ██║█████╗   ╚███╔╝    ██║   ███████║" -ForegroundColor DarkYellow
    Write-Host "  ██║   ██║██║   ██║██║  ██║██╔═══╝ ██║   ██║██   ██║██╔══╝   ██╔██╗    ██║   ██╔══██║" -ForegroundColor DarkYellow
    Write-Host "  ╚██████╔╝╚██████╔╝██████╔╝██║     ╚██████╔╝╚█████╔╝███████╗██╔╝ ██╗   ██║   ██║  ██║" -ForegroundColor Yellow
    Write-Host "   ╚═════╝  ╚═════╝ ╚═════╝ ╚═╝      ╚═════╝  ╚════╝ ╚══════╝╚═╝  ╚═╝   ╚═╝   ╚═╝  ╚═╝" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "   GODPROJEXTH PYTHON GUI RUNNER" -ForegroundColor Yellow
    Write-Host "   PowerShell -> Download Powershell.py -> Open GUI" -ForegroundColor DarkYellow
    Write-Host ""
}

function Write-Status {
    param(
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::Yellow
    )

    Write-Host "   [GODPROJEXTH] $Text" -ForegroundColor $Color
}

function Show-Loader {
    param(
        [string]$Text,
        [int]$From,
        [int]$To
    )

    $barWidth = 42

    for ($i = $From; $i -le $To; $i++) {
        $filled = [math]::Floor(($i / 100) * $barWidth)
        $empty = $barWidth - $filled

        $bar = ("█" * $filled) + ("░" * $empty)

        Write-Host "`r   $Text [$bar] $i%" -NoNewline -ForegroundColor Yellow
        Start-Sleep -Milliseconds 14
    }

    Write-Host ""
}

function Ensure-Folder {
    param([string]$Path)

    if (-not (Test-Path -LiteralPath $Path)) {
        New-Item -ItemType Directory -Path $Path -Force | Out-Null
    }
}

function Test-RawPythonUrl {
    if ([string]::IsNullOrWhiteSpace($PyUrl)) {
        throw "PyUrl is empty."
    }

    try {
        $request = [System.Net.WebRequest]::Create($PyUrl)
        $request.Method = "HEAD"
        $request.UserAgent = "GODPROJEXTH"
        $response = $request.GetResponse()
        $statusCode = [int]$response.StatusCode
        $response.Close()

        if ($statusCode -lt 200 -or $statusCode -ge 400) {
            throw "HTTP $statusCode"
        }
    }
    catch {
        throw "โหลด Powershell.py ไม่ได้ อาจเป็น 404 หรือ URL ผิด ให้เช็คว่าใน GitHub มีไฟล์ชื่อ Powershell.py อยู่จริง และตัวพิมพ์เล็ก/ใหญ่ต้องตรง 100%"
    }
}

function Find-PythonRuntime {
    $candidates = New-Object System.Collections.ArrayList

    $py = Get-Command "py.exe" -ErrorAction SilentlyContinue
    if ($py) {
        [void]$candidates.Add(@{
            File = $py.Source
            Args = @("-3")
            UseWindowed = $false
        })
    }

    $python = Get-Command "python.exe" -ErrorAction SilentlyContinue
    if ($python) {
        [void]$candidates.Add(@{
            File = $python.Source
            Args = @()
            UseWindowed = $false
        })
    }

    try {
        $localPython = Get-ChildItem -Path "$env:LOCALAPPDATA\Programs\Python" -Filter "python.exe" -Recurse -ErrorAction SilentlyContinue |
            Sort-Object FullName -Descending |
            Select-Object -First 1

        if ($localPython) {
            [void]$candidates.Add(@{
                File = $localPython.FullName
                Args = @()
                UseWindowed = $false
            })
        }
    }
    catch {
    }

    foreach ($candidate in $candidates) {
        try {
            $checkArgs = @()
            $checkArgs += $candidate.Args
            $checkArgs += @("-c", "import sys; print(sys.version_info.major)")

            $output = & $candidate.File @checkArgs 2>$null

            if ($LASTEXITCODE -eq 0 -and (($output -join "").Trim() -eq "3")) {
                return $candidate
            }
        }
        catch {
        }
    }

    return $null
}

function Get-WindowedRuntime {
    param($Runtime)

    try {
        if ((Split-Path -Leaf $Runtime.File).ToLower() -eq "python.exe") {
            $dir = Split-Path -Parent $Runtime.File
            $pythonw = Join-Path $dir "pythonw.exe"

            if (Test-Path -LiteralPath $pythonw) {
                return @{
                    File = $pythonw
                    Args = @()
                    UseWindowed = $true
                }
            }
        }

        $pyw = Get-Command "pyw.exe" -ErrorAction SilentlyContinue

        if ($pyw -and ($pyw.Source -notlike "*\WindowsApps\*")) {
            return @{
                File = $pyw.Source
                Args = @("-3")
                UseWindowed = $true
            }
        }
    }
    catch {
    }

    return $Runtime
}

function Download-PythonFile {
    Ensure-Folder -Path $InstallDir

    Show-Loader -Text "Checking raw link       " -From 1 -To 18
    Test-RawPythonUrl

    Show-Loader -Text "Downloading Powershell.py" -From 19 -To 55

    try {
        Invoke-WebRequest -Uri $PyUrl -OutFile $PyPath -UseBasicParsing
    }
    catch {
        throw "ดาวน์โหลด Powershell.py ไม่สำเร็จ: $($_.Exception.Message)"
    }

    if (-not (Test-Path -LiteralPath $PyPath)) {
        throw "Download finished but Powershell.py was not found."
    }
}

function Test-PythonModule {
    param(
        $Runtime,
        [string]$ImportName
    )

    try {
        $args = @()
        $args += $Runtime.Args
        $args += @("-c", "import $ImportName; print('OK')")

        $output = & $Runtime.File @args 2>$null

        if ($LASTEXITCODE -eq 0 -and (($output -join "").Trim() -eq "OK")) {
            return $true
        }
    }
    catch {
    }

    return $false
}

function Install-PythonPackage {
    param(
        $Runtime,
        [string]$PackageName
    )

    $args = @()
    $args += $Runtime.Args
    $args += @("-m", "pip", "install", "--user", "--upgrade", $PackageName)

    & $Runtime.File @args

    if ($LASTEXITCODE -ne 0) {
        throw "ติดตั้ง package ไม่สำเร็จ: $PackageName"
    }
}

function Install-GuiDependencies {
    param($Runtime)

    Show-Loader -Text "Checking dependencies   " -From 56 -To 70

    foreach ($module in $RequiredModules) {
        $importName = $module.ImportName
        $packageName = $module.PackageName

        if (Test-PythonModule -Runtime $Runtime -ImportName $importName) {
            Write-Status "$packageName already installed." Green
            continue
        }

        Write-Status "Installing $packageName..."
        Install-PythonPackage -Runtime $Runtime -PackageName $packageName
    }
}

function Start-PythonGui {
    param($Runtime)

    Show-Loader -Text "Opening GUI             " -From 71 -To 100

    $windowed = Get-WindowedRuntime -Runtime $Runtime

    $args = @()
    $args += $windowed.Args
    $args += @("`"$PyPath`"")

    Start-Process -FilePath $windowed.File -ArgumentList $args -WorkingDirectory $InstallDir
}

try {
    Show-Header

    $runtime = Find-PythonRuntime

    if ($null -eq $runtime) {
        throw "ไม่พบ Python 3 ในเครื่องนี้ กรุณาติดตั้ง Python 3 ก่อน"
    }

    Write-Status "Python found: $($runtime.File)" Green

    Download-PythonFile
    Install-GuiDependencies -Runtime $runtime
    Start-PythonGui -Runtime $runtime

    Write-Host ""
    Write-Status "Done." Green
}
catch {
    Write-Host ""
    Write-Host "   [GODPROJEXTH ERROR]" -ForegroundColor Red
    Write-Host "   $($_.Exception.Message)" -ForegroundColor Red
    Write-Host ""
    Write-Host "   Press Enter to close..." -ForegroundColor Yellow
    [void][System.Console]::ReadLine()
}
