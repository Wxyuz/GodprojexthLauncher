$ErrorActionPreference = "Stop"
$ProgressPreference = "SilentlyContinue"

$AppName = "GODPROJEXTH_GUI"
$InstallDir = Join-Path $env:LOCALAPPDATA "GodprojexthLauncher"
$PyPath = Join-Path $InstallDir "GODPROJEXTH_GUI.py"

# แก้ตรงนี้ให้เป็น RAW link ของไฟล์ .py จริง
$PyUrl = "https://raw.githubusercontent.com/Wxyuz/GodprojexthLauncher/main/GODPROJEXTH_GUI.py"

function Write-GodStatus {
    param(
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::Yellow
    )

    Write-Host "[GODPROJEXTH] $Text" -ForegroundColor $Color
}

function Show-GodLoader {
    param(
        [string]$Text,
        [int]$From,
        [int]$To
    )

    $barWidth = 36

    for ($i = $From; $i -le $To; $i++) {
        $filled = [math]::Floor(($i / 100) * $barWidth)
        $empty = $barWidth - $filled

        $bar = ("█" * $filled) + ("░" * $empty)

        Write-Host "`r[GODPROJEXTH] $Text [$bar] $i%" -NoNewline -ForegroundColor Yellow
        Start-Sleep -Milliseconds 18
    }

    Write-Host ""
}

function Ensure-Folder {
    param([string]$Path)

    if (-not (Test-Path -LiteralPath $Path)) {
        New-Item -ItemType Directory -Path $Path -Force | Out-Null
    }
}

function Test-RawUrl {
    if ([string]::IsNullOrWhiteSpace($PyUrl)) {
        throw "PyUrl is empty."
    }

    try {
        $request = [System.Net.WebRequest]::Create($PyUrl)
        $request.Method = "HEAD"
        $request.UserAgent = "GODPROJEXTH"
        $response = $request.GetResponse()
        $response.Close()
    }
    catch {
        throw "โหลดไฟล์ .py ไม่ได้: 404 หรือ URL ผิด กรุณากด Raw ที่ไฟล์ .py แล้วเอาลิงก์ Raw มาใส่ใน `$PyUrl"
    }
}

function Find-PythonRuntime {
    $candidates = New-Object System.Collections.ArrayList

    $pyw = Get-Command "pyw.exe" -ErrorAction SilentlyContinue
    if ($pyw) {
        [void]$candidates.Add(@{
            File = $pyw.Source
            Args = @("-3")
            Windowed = $true
        })
    }

    $pythonw = Get-Command "pythonw.exe" -ErrorAction SilentlyContinue
    if ($pythonw) {
        [void]$candidates.Add(@{
            File = $pythonw.Source
            Args = @()
            Windowed = $true
        })
    }

    $py = Get-Command "py.exe" -ErrorAction SilentlyContinue
    if ($py) {
        [void]$candidates.Add(@{
            File = $py.Source
            Args = @("-3")
            Windowed = $false
        })
    }

    $python = Get-Command "python.exe" -ErrorAction SilentlyContinue
    if ($python) {
        [void]$candidates.Add(@{
            File = $python.Source
            Args = @()
            Windowed = $false
        })
    }

    foreach ($candidate in $candidates) {
        try {
            $checkArgs = @()
            $checkArgs += $candidate.Args
            $checkArgs += @("-c", "import sys; print(sys.version_info.major)")

            $output = & $candidate.File @checkArgs 2>$null

            if ($LASTEXITCODE -eq 0 -and (($output -join "").Trim() -eq "3")) {
                return $candidate
            }
        }
        catch {
        }
    }

    return $null
}

function Download-PythonFile {
    Ensure-Folder -Path $InstallDir

    Show-GodLoader -Text "Checking raw link" -From 1 -To 20

    Test-RawUrl

    Show-GodLoader -Text "Downloading GUI" -From 21 -To 65

    Invoke-WebRequest -Uri $PyUrl -OutFile $PyPath -UseBasicParsing

    if (-not (Test-Path -LiteralPath $PyPath)) {
        throw "Download finished but .py file was not found."
    }
}

function Install-GuiDependencies {
    param($Runtime)

    Show-GodLoader -Text "Checking dependencies" -From 66 -To 78

    $checkArgs = @()
    $checkArgs += $Runtime.Args
    $checkArgs += @("-c", "import PySide6; print('OK')")

    try {
        $output = & $Runtime.File @checkArgs 2>$null

        if ($LASTEXITCODE -eq 0 -and (($output -join "").Trim() -eq "OK")) {
            Write-GodStatus "PySide6 already installed." Green
            return
        }
    }
    catch {
    }

    Write-GodStatus "Installing PySide6..."

    $pipArgs = @()
    $pipArgs += $Runtime.Args
    $pipArgs += @("-m", "pip", "install", "--user", "--upgrade", "PySide6")

    & $Runtime.File @pipArgs

    if ($LASTEXITCODE -ne 0) {
        throw "Failed to install PySide6."
    }
}

function Start-PythonGui {
    param($Runtime)

    Show-GodLoader -Text "Opening GUI" -From 79 -To 100

    $args = @()
    $args += $Runtime.Args
    $args += @("`"$PyPath`"")

    if ($Runtime.Windowed) {
        Start-Process -FilePath $Runtime.File -ArgumentList $args -WorkingDirectory $InstallDir -WindowStyle Hidden
    }
    else {
        Start-Process -FilePath $Runtime.File -ArgumentList $args -WorkingDirectory $InstallDir
    }
}

try {
    Clear-Host
    Write-Host ""
    Write-Host "  GODPROJEXTH PYTHON GUI RUNNER" -ForegroundColor Yellow
    Write-Host "  PowerShell -> Download .py -> Open GUI" -ForegroundColor DarkYellow
    Write-Host ""

    $runtime = Find-PythonRuntime

    if ($null -eq $runtime) {
        throw "ไม่พบ Python 3 ในเครื่องนี้"
    }

    Write-GodStatus "Python found: $($runtime.File)"

    Download-PythonFile
    Install-GuiDependencies -Runtime $runtime
    Start-PythonGui -Runtime $runtime

    Write-Host ""
    Write-GodStatus "Done." Green
}
catch {
    Write-Host ""
    Write-Host "[GODPROJEXTH ERROR]" -ForegroundColor Red
    Write-Host $_.Exception.Message -ForegroundColor Red
    Write-Host ""
    Write-Host "Press Enter to close..." -ForegroundColor Yellow
    [void][System.Console]::ReadLine()
}
