$ErrorActionPreference = "Stop"
$ProgressPreference = "SilentlyContinue"

$Owner = "Wxyuz"
$Repo = "GodprojexthLauncher"
$AssetName = "Godprojexth_ALPHA_RUN_ALWAYS_ASSET.zip"
$ExpectedSha256 = "FBE6B99C0EE5D7B8D518A5248FBF00723637BF3AE924CDA273B9807AEE1F287C"
$InstallDir = Join-Path $env:LOCALAPPDATA "GodprojexthLauncher"
$TempRoot = Join-Path $env:TEMP "GodprojexthAlphaRunAlways"
$TempZip = Join-Path $TempRoot "GodprojexthAlphaAsset.zip"
$GuiPath = Join-Path $InstallDir "GODPROJEXTH_ALPHA_GUI.ps1"
$GuiBase64 = ""

if (-not ("GodprojexthAlphaLoaderNativeRunAlways" -as [type])) {
Add-Type @"
using System;
using System.Runtime.InteropServices;

public static class GodprojexthAlphaLoaderNativeRunAlways
{
    [DllImport("kernel32.dll")]
    public static extern IntPtr GetConsoleWindow();

    [DllImport("user32.dll")]
    public static extern bool ShowWindow(IntPtr hWnd, int nCmdShow);
}
"@
}

function Show-ConsoleWindow {
    try {
        $handle = [GodprojexthAlphaLoaderNativeRunAlways]::GetConsoleWindow()

        if ($handle -ne [IntPtr]::Zero) {
            [GodprojexthAlphaLoaderNativeRunAlways]::ShowWindow($handle, 5) | Out-Null
        }
    }
    catch {
    }
}

function Initialize-Loader {
    try {
        [Console]::OutputEncoding = [System.Text.Encoding]::UTF8
    }
    catch {
    }

    try {
        [Console]::CursorVisible = $false
    }
    catch {
    }

    Clear-Host

    Write-Host ""
    Write-Host "  GODPROJEXTH ALPHA" -ForegroundColor Yellow
    Write-Host "  Run Always Loader" -ForegroundColor DarkYellow
    Write-Host ""
    Write-Host "  Status : Preparing..." -ForegroundColor Yellow
    Write-Host ""
    Write-Host "  [--------------------------------------------]   0%" -ForegroundColor DarkYellow
    Write-Host ""
    Write-Host "  Frame  : 0000" -ForegroundColor DarkYellow
    Write-Host ""
    Write-Host "  SHA mismatch will not stop the launcher." -ForegroundColor DarkYellow
}

function Safe-WriteLine {
    param(
        [int]$Top,
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::White
    )

    try {
        $width = [Console]::WindowWidth
        $height = [Console]::WindowHeight

        if ($width -lt 60) {
            $width = 120
        }

        if ($height -le ($Top + 1)) {
            return
        }

        if ([string]::IsNullOrEmpty($Text)) {
            $Text = ""
        }

        if ($Text.Length -gt ($width - 1)) {
            $Text = $Text.Substring(0, $width - 1)
        }

        $padded = $Text.PadRight($width - 1)

        [Console]::SetCursorPosition(0, $Top)
        Write-Host $padded -NoNewline -ForegroundColor $Color
    }
    catch {
    }
}

function Draw-GoldLoader {
    param(
        [string]$Status,
        [int]$Percent,
        [int]$Frame
    )

    $Percent = [Math]::Max(0, [Math]::Min(100, $Percent))

    $barWidth = 44
    $filled = [int][Math]::Floor(($Percent / 100) * $barWidth)

    if ($filled -lt 0) {
        $filled = 0
    }

    if ($filled -gt $barWidth) {
        $filled = $barWidth
    }

    $empty = $barWidth - $filled

    if ($filled -eq 0) {
        $bar = "-" * $barWidth
    }
    elseif ($filled -ge $barWidth) {
        $bar = "#" * $barWidth
    }
    else {
        $bar = ("#" * $filled) + ("-" * $empty)
    }

    $spinnerChars = @("|", "/", "-", "\")
    $spinner = $spinnerChars[$Frame % $spinnerChars.Count]

    Safe-WriteLine -Top 4 -Text ("  Status : {0} {1}" -f $Status, $spinner) -Color Yellow
    Safe-WriteLine -Top 6 -Text ("  +{0}+" -f ("=" * $barWidth)) -Color DarkYellow
    Safe-WriteLine -Top 7 -Text ("  |{0}| {1,3}%" -f $bar, $Percent) -Color Yellow
    Safe-WriteLine -Top 8 -Text ("  +{0}+" -f ("=" * $barWidth)) -Color DarkYellow
    Safe-WriteLine -Top 10 -Text ("  Frame  : {0:0000}" -f $Frame) -Color DarkYellow
}

function Animate-ToPercent {
    param(
        [int]$From,
        [int]$To,
        [string]$Status,
        [ref]$FrameRef
    )

    if ($To -lt $From) {
        $To = $From
    }

    for ($value = $From; $value -le $To; $value++) {
        Draw-GoldLoader -Status $Status -Percent $value -Frame $FrameRef.Value
        $FrameRef.Value++
        Start-Sleep -Milliseconds 16
    }

    return $To
}

function Download-FileSmooth {
    param(
        [string]$Url,
        [string]$OutFile,
        [hashtable]$Headers,
        [ref]$FrameRef
    )

    $request = [System.Net.HttpWebRequest]::Create($Url)
    $request.Method = "GET"
    $request.AllowAutoRedirect = $true
    $request.UserAgent = $Headers["User-Agent"]

    $response = $null
    $inputStream = $null
    $outputStream = $null

    try {
        $response = $request.GetResponse()
        $totalBytes = $response.ContentLength

        $inputStream = $response.GetResponseStream()
        $outputStream = [System.IO.File]::Create($OutFile)

        $buffer = New-Object byte[] 65536
        $totalRead = 0L
        $lastDraw = [Environment]::TickCount

        while ($true) {
            $read = $inputStream.Read($buffer, 0, $buffer.Length)

            if ($read -le 0) {
                break
            }

            $outputStream.Write($buffer, 0, $read)
            $totalRead += $read

            $now = [Environment]::TickCount

            if (($now - $lastDraw) -ge 16) {
                if ($totalBytes -gt 0) {
                    $downloadPercent = [int](35 + (($totalRead / $totalBytes) * 28))
                    Draw-GoldLoader -Status "Downloading package..." -Percent $downloadPercent -Frame $FrameRef.Value
                }
                else {
                    $softPercent = 42 + ($FrameRef.Value % 18)
                    Draw-GoldLoader -Status "Downloading package..." -Percent $softPercent -Frame $FrameRef.Value
                }

                $FrameRef.Value++
                $lastDraw = $now
            }
        }

        return $true
    }
    catch {
        return $false
    }
    finally {
        if ($outputStream -ne $null) {
            $outputStream.Close()
            $outputStream.Dispose()
        }

        if ($inputStream -ne $null) {
            $inputStream.Close()
            $inputStream.Dispose()
        }

        if ($response -ne $null) {
            $response.Close()
        }
    }
}

function Get-GoldPixelWord {
    $font = @{}

    $font["G"] = @(" ### ","#    ","#  ##","#   #"," ### ")
    $font["O"] = @(" ### ","#   #","#   #","#   #"," ### ")
    $font["D"] = @("#### ","#   #","#   #","#   #","#### ")
    $font["P"] = @("#### ","#   #","#### ","#    ","#    ")
    $font["R"] = @("#### ","#   #","#### ","#  # ","#   #")
    $font["J"] = @("  ###","   # ","   # ","#  # "," ##  ")
    $font["E"] = @("#####","#    ","#### ","#    ","#####")
    $font["X"] = @("#   #"," # # ","  #  "," # # ","#   #")
    $font["T"] = @("#####","  #  ","  #  ","  #  ","  #  ")
    $font["H"] = @("#   #","#   #","#####","#   #","#   #")

    $word = "GODPROJEXTH"
    $lines = @("", "", "", "", "")

    foreach ($char in $word.ToCharArray()) {
        $glyph = $font[[string]$char]

        for ($row = 0; $row -lt 5; $row++) {
            $lines[$row] += $glyph[$row] + " "
        }
    }

    return $lines
}

function Show-GoldGodCredit {
    param([ref]$FrameRef)

    Clear-Host

    $art = Get-GoldPixelWord
    $maxLength = ($art | ForEach-Object { $_.Length } | Measure-Object -Maximum).Maximum

    Write-Host ""
    Write-Host ""
    Write-Host "  CREDIT" -ForegroundColor DarkYellow
    Write-Host ""

    for ($column = 1; $column -le $maxLength; $column++) {
        for ($row = 0; $row -lt $art.Count; $row++) {
            $line = $art[$row]

            if ($column -gt $line.Length) {
                $part = $line
            }
            else {
                $part = $line.Substring(0, $column)
            }

            if ($row -eq 0) {
                $color = [System.ConsoleColor]::White
            }
            elseif ($row -eq 1) {
                $color = [System.ConsoleColor]::Yellow
            }
            elseif ($row -eq 2) {
                $color = [System.ConsoleColor]::Yellow
            }
            elseif ($row -eq 3) {
                $color = [System.ConsoleColor]::DarkYellow
            }
            else {
                $color = [System.ConsoleColor]::DarkYellow
            }

            Safe-WriteLine -Top (4 + $row) -Text ("  " + $part) -Color $color
        }

        Safe-WriteLine -Top 11 -Text ("  GOLD PIXEL CREDIT  frame {0:0000}" -f $FrameRef.Value) -Color DarkYellow
        $FrameRef.Value++
        Start-Sleep -Milliseconds 24
    }

    for ($shine = 0; $shine -lt 25; $shine++) {
        for ($row = 0; $row -lt $art.Count; $row++) {
            $phase = ($shine + $row) % 5

            if ($phase -eq 0) {
                $color = [System.ConsoleColor]::White
            }
            elseif ($phase -eq 1) {
                $color = [System.ConsoleColor]::Yellow
            }
            elseif ($phase -eq 2) {
                $color = [System.ConsoleColor]::Yellow
            }
            elseif ($phase -eq 3) {
                $color = [System.ConsoleColor]::DarkYellow
            }
            else {
                $color = [System.ConsoleColor]::Yellow
            }

            Safe-WriteLine -Top (4 + $row) -Text ("  " + $art[$row]) -Color $color
        }

        Safe-WriteLine -Top 11 -Text ("  Opening detached GUI... frame {0:0000}" -f $FrameRef.Value) -Color DarkYellow
        $FrameRef.Value++
        Start-Sleep -Milliseconds 16
    }
}

function Write-DetachedGuiFile {
    param([string]$Path)

    $folder = Split-Path -Parent $Path

    if (-not (Test-Path -LiteralPath $folder)) {
        New-Item -ItemType Directory -Path $folder -Force | Out-Null
    }

    $bytes = [Convert]::FromBase64String($GuiBase64)
    $source = [System.Text.Encoding]::UTF8.GetString($bytes)

    Set-Content -LiteralPath $Path -Value $source -Encoding UTF8 -Force
}

function Start-DetachedGui {
    param([string]$Path)

    if (-not (Test-Path -LiteralPath $Path)) {
        throw "GUI file not found: $Path"
    }

    $powerShellExe = Join-Path $PSHOME "powershell.exe"

    if (-not (Test-Path -LiteralPath $powerShellExe)) {
        $powerShellExe = "powershell.exe"
    }

    $markerPath = Join-Path $env:TEMP ("GODPROJEXTH_ALPHA_GUI_READY_" + [Guid]::NewGuid().ToString("N") + ".flag")
    Remove-Item -LiteralPath $markerPath -Force -ErrorAction SilentlyContinue

    $cmdLine = '/d /c start "" "' + $powerShellExe + '" -NoProfile -ExecutionPolicy Bypass -STA -WindowStyle Normal -File "' + $Path + '" -MarkerPath "' + $markerPath + '"'

    Start-Process -FilePath "cmd.exe" -ArgumentList $cmdLine -WindowStyle Hidden | Out-Null

    for ($waitIndex = 0; $waitIndex -lt 120; $waitIndex++) {
        if (Test-Path -LiteralPath $markerPath) {
            return $true
        }

        Start-Sleep -Milliseconds 100
    }

    return $true
}

function Try-DownloadAsset {
    param([ref]$FrameRef)

    $headers = @{
        "User-Agent" = "GodprojexthAlphaInstaller"
    }

    try {
        $releaseApi = "https://api.github.com/repos/$Owner/$Repo/releases/latest"
        Draw-GoldLoader -Status "Reading latest release..." -Percent 16 -Frame $FrameRef.Value
        $FrameRef.Value++

        $release = Invoke-RestMethod -Uri $releaseApi -Headers $headers

        $asset = $release.assets |
            Where-Object { $_.name -eq $AssetName } |
            Select-Object -First 1

        if (-not $asset) {
            Draw-GoldLoader -Status "Asset not found, continuing..." -Percent 28 -Frame $FrameRef.Value
            $FrameRef.Value++
            Start-Sleep -Milliseconds 450
            return $false
        }

        Remove-Item $TempRoot -Recurse -Force -ErrorAction SilentlyContinue
        New-Item -ItemType Directory -Path $TempRoot -Force | Out-Null

        $downloadOk = Download-FileSmooth -Url $asset.browser_download_url -OutFile $TempZip -Headers $headers -FrameRef $FrameRef

        if (-not $downloadOk) {
            Draw-GoldLoader -Status "Download failed, continuing..." -Percent 64 -Frame $FrameRef.Value
            $FrameRef.Value++
            Start-Sleep -Milliseconds 450
            return $false
        }

        Draw-GoldLoader -Status "Checking SHA256..." -Percent 72 -Frame $FrameRef.Value
        $FrameRef.Value++

        try {
            $actualHash = (Get-FileHash $TempZip -Algorithm SHA256).Hash.ToUpperInvariant()

            if ($actualHash -ne $ExpectedSha256.ToUpperInvariant()) {
                Draw-GoldLoader -Status "SHA changed, continuing..." -Percent 76 -Frame $FrameRef.Value
                $FrameRef.Value++
                Start-Sleep -Milliseconds 650
            }
            else {
                Draw-GoldLoader -Status "SHA verified..." -Percent 76 -Frame $FrameRef.Value
                $FrameRef.Value++
                Start-Sleep -Milliseconds 250
            }
        }
        catch {
            Draw-GoldLoader -Status "SHA check skipped..." -Percent 76 -Frame $FrameRef.Value
            $FrameRef.Value++
            Start-Sleep -Milliseconds 250
        }

        try {
            New-Item -ItemType Directory -Path $InstallDir -Force | Out-Null
            Expand-Archive -Path $TempZip -DestinationPath $InstallDir -Force
        }
        catch {
            Draw-GoldLoader -Status "ZIP install skipped..." -Percent 82 -Frame $FrameRef.Value
            $FrameRef.Value++
            Start-Sleep -Milliseconds 350
        }

        return $true
    }
    catch {
        Draw-GoldLoader -Status "Asset check skipped..." -Percent 64 -Frame $FrameRef.Value
        $FrameRef.Value++
        Start-Sleep -Milliseconds 450
        return $false
    }
}

try {
    [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

    Initialize-Loader

    $frame = 0
    $progress = 0

    $progress = Animate-ToPercent -From $progress -To 12 -Status "Preparing loader..." -FrameRef ([ref]$frame)

    [void](Try-DownloadAsset -FrameRef ([ref]$frame))

    $progress = Animate-ToPercent -From 76 -To 92 -Status "Preparing detached GUI..." -FrameRef ([ref]$frame)

    New-Item -ItemType Directory -Path $InstallDir -Force | Out-Null
    Write-DetachedGuiFile -Path $GuiPath

    $progress = Animate-ToPercent -From $progress -To 100 -Status "Completed. Showing credit..." -FrameRef ([ref]$frame)

    Show-GoldGodCredit -FrameRef ([ref]$frame)

    Start-DetachedGui -Path $GuiPath | Out-Null

    Start-Sleep -Milliseconds 700

    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    exit 0
}
catch {
    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    Show-ConsoleWindow

    Clear-Host
    Write-Host ""
    Write-Host "  GODPROJEXTH ALPHA ERROR" -ForegroundColor Red
    Write-Host ""
    Write-Host "  $($_.Exception.Message)" -ForegroundColor Red
    Write-Host ""
    Write-Host "  Press Enter to close..." -ForegroundColor Yellow
    [void][System.Console]::ReadLine()
}
