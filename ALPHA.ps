        int nLeftRect,
        int nTopRect,
        int nRightRect,
        int nBottomRect,
        int nWidthEllipse,
        int nHeightEllipse
    );

    [DllImport("user32.dll")]
    public static extern bool SetProcessDPIAware();

    [DllImport("user32.dll")]
    public static extern bool SetForegroundWindow(IntPtr hWnd);

    [DllImport("user32.dll")]
    public static extern bool BringWindowToTop(IntPtr hWnd);
}
"@
    }

    try {
        [GodprojexthDetachedGuiNativeV10]::SetProcessDPIAware() | Out-Null
    }
    catch {
    }

    function Hide-GuiConsole {
        try {
            $handle = [GodprojexthDetachedGuiNativeV10]::GetConsoleWindow()

            if ($handle -ne [IntPtr]::Zero) {
                [GodprojexthDetachedGuiNativeV10]::ShowWindow($handle, 0) | Out-Null
            }
        }
        catch {
        }
    }

    function New-C {
        param([string]$Hex)

        return [System.Drawing.ColorTranslator]::FromHtml($Hex)
    }

    $screen = [System.Windows.Forms.Screen]::PrimaryScreen.WorkingArea
    $baseWidth = 430
    $baseHeight = 640
    $script:Scale = [Math]::Min(1.0, [Math]::Min(($screen.Width * 0.92) / $baseWidth, ($screen.Height * 0.92) / $baseHeight))

    if ($script:Scale -lt 0.82) {
        $script:Scale = 0.82
    }

    function U {
        param([double]$Value)

        return [int][Math]::Round($Value * $script:Scale)
    }

    function New-Font {
        param(
            [double]$Size,
            [System.Drawing.FontStyle]$Style = [System.Drawing.FontStyle]::Regular
        )

        return New-Object System.Drawing.Font("Segoe UI", [float]([Math]::Max(6.0, $Size * $script:Scale)), $Style)
    }

    function Set-Round {
        param(
            [System.Windows.Forms.Control]$Control,
            [int]$Radius
        )

        try {
            if ($null -eq $Control) {
                return
            }

            if ($Control.Width -le 0 -or $Control.Height -le 0) {
                return
            }

            $round = [Math]::Max(2, (U $Radius))
            $regionPointer = [GodprojexthDetachedGuiNativeV10]::CreateRoundRectRgn(
                0,
                0,
                $Control.Width + 1,
                $Control.Height + 1,
                $round,
                $round
            )

            $Control.Region = [System.Drawing.Region]::FromHrgn($regionPointer)
        }
        catch {
        }
    }

    function Enable-Drag {
        param(
            [System.Windows.Forms.Control]$Control,
            [System.Windows.Forms.Form]$Form
        )

        if ($null -eq $Control -or $null -eq $Form) {
            return
        }

        $script:AlphaDragForm = $Form

        $Control.Add_MouseDown({
            try {
                if ($_.Button -eq [System.Windows.Forms.MouseButtons]::Left) {
                    $script:AlphaDragActive = $true
                    $script:AlphaDragMouseStart = [System.Windows.Forms.Control]::MousePosition
                    $script:AlphaDragFormStart = $script:AlphaDragForm.Location

                    try {
                        $this.Capture = $true
                    }
                    catch {
                    }
                }
            }
            catch {
                $script:AlphaDragActive = $false
            }
        })

        $Control.Add_MouseMove({
            try {
                if ($script:AlphaDragActive -ne $true) {
                    return
                }

                if ($null -eq $script:AlphaDragForm) {
                    $script:AlphaDragActive = $false
                    return
                }

                if ($script:AlphaDragForm.IsDisposed) {
                    $script:AlphaDragActive = $false
                    return
                }

                $mouseButtons = [int][System.Windows.Forms.Control]::MouseButtons
                $leftButton = [int][System.Windows.Forms.MouseButtons]::Left

                if (($mouseButtons -band $leftButton) -eq 0) {
                    $script:AlphaDragActive = $false
                    return
                }

                $currentMouse = [System.Windows.Forms.Control]::MousePosition
                $deltaX = $currentMouse.X - $script:AlphaDragMouseStart.X
                $deltaY = $currentMouse.Y - $script:AlphaDragMouseStart.Y

                $newX = $script:AlphaDragFormStart.X + $deltaX
                $newY = $script:AlphaDragFormStart.Y + $deltaY

                $script:AlphaDragForm.Location = New-Object System.Drawing.Point($newX, $newY)
            }
            catch {
                $script:AlphaDragActive = $false
            }
        })

        $Control.Add_MouseUp({
            try {
                $script:AlphaDragActive = $false

                try {
                    $this.Capture = $false
                }
                catch {
                }
            }
            catch {
                $script:AlphaDragActive = $false
            }
        })
    }

    function Bring-LoginFront {
        param([System.Windows.Forms.Form]$Form)

        try {
            if ($null -eq $Form) {
                return
            }

            if ($Form.IsDisposed) {
                return
            }

            $Form.WindowState = [System.Windows.Forms.FormWindowState]::Normal
            $Form.Show()
            $Form.Activate()
            $Form.Focus()
            $Form.BringToFront()

            [GodprojexthDetachedGuiNativeV10]::BringWindowToTop($Form.Handle) | Out-Null
            [GodprojexthDetachedGuiNativeV10]::SetForegroundWindow($Form.Handle) | Out-Null
        }
        catch {
        }
    }

