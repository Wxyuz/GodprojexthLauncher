$ErrorActionPreference = "Stop"
$ProgressPreference = "SilentlyContinue"

$InstallDir = Join-Path $env:LOCALAPPDATA "GodprojexthLauncher"
$PythonGuiPath = Join-Path $InstallDir "GODPROJEXTH_GUI.py"
$PythonGuiBase64 = ""

if (-not ("GodprojexthAlphaPyShowGuiNativeV2" -as [type])) {
Add-Type @"
using System;
using System.Runtime.InteropServices;

public static class GodprojexthAlphaPyShowGuiNativeV2
{
    [DllImport("kernel32.dll")]
    public static extern IntPtr GetConsoleWindow();

    [DllImport("user32.dll")]
    public static extern bool ShowWindow(IntPtr hWnd, int nCmdShow);
}
"@
}

function Show-ConsoleWindow {
    try {
        $handle = [GodprojexthAlphaPyShowGuiNativeV2]::GetConsoleWindow()

        if ($handle -ne [IntPtr]::Zero) {
            [GodprojexthAlphaPyShowGuiNativeV2]::ShowWindow($handle, 5) | Out-Null
        }
    }
    catch {
    }
}

function Initialize-Loader {
    try {
        [Console]::OutputEncoding = [System.Text.Encoding]::UTF8
    }
    catch {
    }

    try {
        [Console]::CursorVisible = $false
    }
    catch {
    }

    Clear-Host

    Write-Host ""
    Write-Host "  GODPROJEXTH ALPHA" -ForegroundColor Yellow
    Write-Host "  Python GUI Launcher" -ForegroundColor DarkYellow
    Write-Host ""
    Write-Host "  Status : Preparing..." -ForegroundColor Yellow
    Write-Host ""
    Write-Host "  [--------------------------------------------]   0%" -ForegroundColor DarkYellow
    Write-Host ""
    Write-Host "  Frame  : 0000" -ForegroundColor DarkYellow
    Write-Host ""
    Write-Host "  After loading, this will open GODPROJEXTH_GUI.py" -ForegroundColor DarkYellow
}

function Safe-WriteLine {
    param(
        [int]$Top,
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::White
    )

    try {
        $width = [Console]::WindowWidth
        $height = [Console]::WindowHeight

        if ($width -lt 60) {
            $width = 120
        }

        if ($height -le ($Top + 1)) {
            return
        }

        if ([string]::IsNullOrEmpty($Text)) {
            $Text = ""
        }

        if ($Text.Length -gt ($width - 1)) {
            $Text = $Text.Substring(0, $width - 1)
        }

        $padded = $Text.PadRight($width - 1)

        [Console]::SetCursorPosition(0, $Top)
        Write-Host $padded -NoNewline -ForegroundColor $Color
    }
    catch {
    }
}

function Draw-GoldLoader {
    param(
        [string]$Status,
        [int]$Percent,
        [int]$Frame
    )

    $Percent = [Math]::Max(0, [Math]::Min(100, $Percent))

    $barWidth = 44
    $filled = [int][Math]::Floor(($Percent / 100) * $barWidth)

    if ($filled -lt 0) {
        $filled = 0
    }

    if ($filled -gt $barWidth) {
        $filled = $barWidth
    }

    $empty = $barWidth - $filled

    if ($filled -eq 0) {
        $bar = "-" * $barWidth
    }
    elseif ($filled -ge $barWidth) {
        $bar = "#" * $barWidth
    }
    else {
        $bar = ("#" * $filled) + ("-" * $empty)
    }

    $spinnerChars = @("|", "/", "-", "\")
    $spinner = $spinnerChars[$Frame % $spinnerChars.Count]

    Safe-WriteLine -Top 4 -Text ("  Status : {0} {1}" -f $Status, $spinner) -Color Yellow
    Safe-WriteLine -Top 6 -Text ("  +{0}+" -f ("=" * $barWidth)) -Color DarkYellow
    Safe-WriteLine -Top 7 -Text ("  |{0}| {1,3}%" -f $bar, $Percent) -Color Yellow
    Safe-WriteLine -Top 8 -Text ("  +{0}+" -f ("=" * $barWidth)) -Color DarkYellow
    Safe-WriteLine -Top 10 -Text ("  Frame  : {0:0000}" -f $Frame) -Color DarkYellow
}

function Animate-ToPercent {
    param(
        [int]$From,
        [int]$To,
        [string]$Status,
        [ref]$FrameRef
    )

    if ($To -lt $From) {
        $To = $From
    }

    for ($value = $From; $value -le $To; $value++) {
        Draw-GoldLoader -Status $Status -Percent $value -Frame $FrameRef.Value
        $FrameRef.Value++
        Start-Sleep -Milliseconds 16
    }

    return $To
}

function Get-GoldPixelWord {
    $font = @{}

    $font["G"] = @(" ### ","#    ","#  ##","#   #"," ### ")
    $font["O"] = @(" ### ","#   #","#   #","#   #"," ### ")
    $font["D"] = @("#### ","#   #","#   #","#   #","#### ")
    $font["P"] = @("#### ","#   #","#### ","#    ","#    ")
    $font["R"] = @("#### ","#   #","#### ","#  # ","#   #")
    $font["J"] = @("  ###","   # ","   # ","#  # "," ##  ")
    $font["E"] = @("#####","#    ","#### ","#    ","#####")
    $font["X"] = @("#   #"," # # ","  #  "," # # ","#   #")
    $font["T"] = @("#####","  #  ","  #  ","  #  ","  #  ")
    $font["H"] = @("#   #","#   #","#####","#   #","#   #")

    $word = "GODPROJEXTH"
    $lines = @("", "", "", "", "")

    foreach ($char in $word.ToCharArray()) {
        $glyph = $font[[string]$char]

        for ($row = 0; $row -lt 5; $row++) {
            $lines[$row] += $glyph[$row] + " "
        }
    }

    return $lines
}

function Show-GoldGodCredit {
    param([ref]$FrameRef)

    Clear-Host

    $art = Get-GoldPixelWord
    $maxLength = ($art | ForEach-Object { $_.Length } | Measure-Object -Maximum).Maximum

    Write-Host ""
    Write-Host ""
    Write-Host "  CREDIT" -ForegroundColor DarkYellow
    Write-Host ""

    for ($column = 1; $column -le $maxLength; $column++) {
        for ($row = 0; $row -lt $art.Count; $row++) {
            $line = $art[$row]

            if ($column -gt $line.Length) {
                $part = $line
            }
            else {
                $part = $line.Substring(0, $column)
            }

            if ($row -eq 0) {
                $color = [System.ConsoleColor]::White
            }
            elseif ($row -eq 1) {
                $color = [System.ConsoleColor]::Yellow
            }
            elseif ($row -eq 2) {
                $color = [System.ConsoleColor]::Yellow
            }
            elseif ($row -eq 3) {
                $color = [System.ConsoleColor]::DarkYellow
            }
            else {
                $color = [System.ConsoleColor]::DarkYellow
            }

            Safe-WriteLine -Top (4 + $row) -Text ("  " + $part) -Color $color
        }

        Safe-WriteLine -Top 11 -Text ("  PYTHON GUI CREDIT  frame {0:0000}" -f $FrameRef.Value) -Color DarkYellow
        $FrameRef.Value++
        Start-Sleep -Milliseconds 24
    }

    for ($shine = 0; $shine -lt 25; $shine++) {
        for ($row = 0; $row -lt $art.Count; $row++) {
            $phase = ($shine + $row) % 5

            if ($phase -eq 0) {
                $color = [System.ConsoleColor]::White
            }
            elseif ($phase -eq 1) {
                $color = [System.ConsoleColor]::Yellow
            }
            elseif ($phase -eq 2) {
                $color = [System.ConsoleColor]::Yellow
            }
            elseif ($phase -eq 3) {
                $color = [System.ConsoleColor]::DarkYellow
            }
            else {
                $color = [System.ConsoleColor]::Yellow
            }

            Safe-WriteLine -Top (4 + $row) -Text ("  " + $art[$row]) -Color $color
        }

        Safe-WriteLine -Top 11 -Text ("  Opening GODPROJEXTH_GUI.py... frame {0:0000}" -f $FrameRef.Value) -Color DarkYellow
        $FrameRef.Value++
        Start-Sleep -Milliseconds 16
    }
}

function Write-PythonGuiFile {
    param([string]$Path)

    $folder = Split-Path -Parent $Path

    if (-not (Test-Path -LiteralPath $folder)) {
        New-Item -ItemType Directory -Path $folder -Force | Out-Null
    }

    $bytes = [Convert]::FromBase64String($PythonGuiBase64)
    $source = [System.Text.Encoding]::UTF8.GetString($bytes)

    Set-Content -LiteralPath $Path -Value $source -Encoding UTF8 -Force
}

function Find-PythonLauncher {
    $launchers = New-Object System.Collections.ArrayList

    $pyw = Get-Command "pyw.exe" -ErrorAction SilentlyContinue
    if ($pyw) {
        [void]$launchers.Add(@{ File = $pyw.Source; Args = @("-3", "`"$PythonGuiPath`"") })
    }

    $pythonw = Get-Command "pythonw.exe" -ErrorAction SilentlyContinue
    if ($pythonw) {
        [void]$launchers.Add(@{ File = $pythonw.Source; Args = @("`"$PythonGuiPath`"") })
    }

    try {
        $localPythonw = Get-ChildItem -Path "$env:LOCALAPPDATA\Programs\Python" -Filter "pythonw.exe" -Recurse -ErrorAction SilentlyContinue |
            Sort-Object FullName -Descending |
            Select-Object -First 1

        if ($localPythonw) {
            [void]$launchers.Add(@{ File = $localPythonw.FullName; Args = @("`"$PythonGuiPath`"") })
        }
    }
    catch {
    }

    $py = Get-Command "py.exe" -ErrorAction SilentlyContinue
    if ($py) {
        [void]$launchers.Add(@{ File = $py.Source; Args = @("-3", "`"$PythonGuiPath`"") })
    }

    $python = Get-Command "python.exe" -ErrorAction SilentlyContinue
    if ($python) {
        [void]$launchers.Add(@{ File = $python.Source; Args = @("`"$PythonGuiPath`"") })
    }

    return $launchers
}

function Start-PythonGui {
    $launchers = Find-PythonLauncher

    foreach ($launcher in $launchers) {
        try {
            Start-Process -FilePath $launcher.File -ArgumentList $launcher.Args -WindowStyle Normal | Out-Null
            return $true
        }
        catch {
        }
    }

    try {
        Start-Process -FilePath $PythonGuiPath -WindowStyle Normal | Out-Null
        return $true
    }
    catch {
    }

    throw "Python not found. Install Python 3 first, then run ALPHA.ps again. GUI file created here: $PythonGuiPath"
}

try {
    Initialize-Loader

    $frame = 0
    $progress = 0

    $progress = Animate-ToPercent -From $progress -To 22 -Status "Preparing loader..." -FrameRef ([ref]$frame)
    $progress = Animate-ToPercent -From $progress -To 48 -Status "Writing GODPROJEXTH_GUI.py..." -FrameRef ([ref]$frame)

    New-Item -ItemType Directory -Path $InstallDir -Force | Out-Null
    Write-PythonGuiFile -Path $PythonGuiPath

    $progress = Animate-ToPercent -From $progress -To 76 -Status "Checking Python launcher..." -FrameRef ([ref]$frame)
    $launchers = Find-PythonLauncher

    if ($launchers.Count -le 0) {
        throw "Python not found. Install Python 3 first. GUI file created here: $PythonGuiPath"
    }

    $progress = Animate-ToPercent -From $progress -To 100 -Status "Completed. Showing credit..." -FrameRef ([ref]$frame)

    Show-GoldGodCredit -FrameRef ([ref]$frame)

    Start-PythonGui | Out-Null

    Start-Sleep -Milliseconds 700

    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    exit 0
}
catch {
    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    Show-ConsoleWindow

    Clear-Host
    Write-Host ""
    Write-Host "  GODPROJEXTH ALPHA ERROR" -ForegroundColor Red
    Write-Host ""
    Write-Host "  $($_.Exception.Message)" -ForegroundColor Red
    Write-Host ""
    Write-Host "  Created GUI.py path:" -ForegroundColor Yellow
    Write-Host "  $PythonGuiPath" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "  Press Enter to close..." -ForegroundColor Yellow
    [void][System.Console]::ReadLine()
}
