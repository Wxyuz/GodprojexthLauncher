$ErrorActionPreference = "Stop"
$ProgressPreference = "SilentlyContinue"

$InstallDir = Join-Path $env:LOCALAPPDATA "GodprojexthLauncher"
$InterfacePath = Join-Path $InstallDir "GODPROJEXTH_GUI.py"
$InterfacePayload = ""
$ErrorLog = Join-Path $env:TEMP "GODPROJEXTH_ALPHA_INTERFACE_LOADER_ERROR.log"

if (-not ("GodprojexthAlphaInterfaceNativeV5" -as [type])) {
Add-Type @"
using System;
using System.Runtime.InteropServices;

public static class GodprojexthAlphaInterfaceNativeV5
{
    [DllImport("kernel32.dll")]
    public static extern IntPtr GetConsoleWindow();

    [DllImport("user32.dll")]
    public static extern bool ShowWindow(IntPtr hWnd, int nCmdShow);
}
"@
}

function Show-ConsoleWindow {
    try {
        $handle = [GodprojexthAlphaInterfaceNativeV5]::GetConsoleWindow()

        if ($handle -ne [IntPtr]::Zero) {
            [GodprojexthAlphaInterfaceNativeV5]::ShowWindow($handle, 5) | Out-Null
        }
    }
    catch {
    }
}

function Initialize-Loader {
    try {
        [Console]::OutputEncoding = [System.Text.Encoding]::UTF8
    }
    catch {
    }

    try {
        [Console]::CursorVisible = $false
    }
    catch {
    }

    Clear-Host

    Write-Host ""
    Write-Host "  GODPROJEXTH ALPHA" -ForegroundColor Yellow
    Write-Host "  Protected Interface Loader" -ForegroundColor DarkYellow
    Write-Host ""
    Write-Host "  Status : Secure session starting..." -ForegroundColor Yellow
    Write-Host ""
    Write-Host "  [--------------------------------------------]   0%" -ForegroundColor DarkYellow
    Write-Host ""
    Write-Host "  Frame  : 0000" -ForegroundColor DarkYellow
    Write-Host ""
    Write-Host "  Protected mode: interface payload is hidden from this screen." -ForegroundColor DarkYellow
    Write-Host "  Preparing GODPROJEXTH secure interface..." -ForegroundColor DarkYellow
}

function Safe-WriteLine {
    param(
        [int]$Top,
        [string]$Text,
        [System.ConsoleColor]$Color = [System.ConsoleColor]::White
    )

    try {
        $width = [Console]::WindowWidth
        $height = [Console]::WindowHeight

        if ($width -lt 60) {
            $width = 120
        }

        if ($height -le ($Top + 1)) {
            return
        }

        if ([string]::IsNullOrEmpty($Text)) {
            $Text = ""
        }

        if ($Text.Length -gt ($width - 1)) {
            $Text = $Text.Substring(0, $width - 1)
        }

        $padded = $Text.PadRight($width - 1)

        [Console]::SetCursorPosition(0, $Top)
        Write-Host $padded -NoNewline -ForegroundColor $Color
    }
    catch {
    }
}

function Draw-ProtectedLoader {
    param(
        [string]$Status,
        [int]$Percent,
        [int]$Frame
    )

    $Percent = [Math]::Max(0, [Math]::Min(100, $Percent))
    $barWidth = 44
    $filled = [int][Math]::Floor(($Percent / 100) * $barWidth)

    if ($filled -lt 0) {
        $filled = 0
    }

    if ($filled -gt $barWidth) {
        $filled = $barWidth
    }

    $empty = $barWidth - $filled

    if ($filled -eq 0) {
        $bar = "-" * $barWidth
    }
    elseif ($filled -ge $barWidth) {
        $bar = "#" * $barWidth
    }
    else {
        $bar = ("#" * $filled) + ("-" * $empty)
    }

    $spinnerChars = @("|", "/", "-", "\")
    $spinner = $spinnerChars[$Frame % $spinnerChars.Count]

    Safe-WriteLine -Top 4 -Text ("  Status : {0} {1}" -f $Status, $spinner) -Color Yellow
    Safe-WriteLine -Top 6 -Text ("  +{0}+" -f ("=" * $barWidth)) -Color DarkYellow
    Safe-WriteLine -Top 7 -Text ("  |{0}| {1,3}%" -f $bar, $Percent) -Color Yellow
    Safe-WriteLine -Top 8 -Text ("  +{0}+" -f ("=" * $barWidth)) -Color DarkYellow
    Safe-WriteLine -Top 10 -Text ("  Frame  : {0:0000}" -f $Frame) -Color DarkYellow
    Safe-WriteLine -Top 12 -Text "  Protected: preparing interface without printing internal payload..." -Color DarkYellow
}

function Animate-ToPercent {
    param(
        [int]$From,
        [int]$To,
        [string]$Status,
        [ref]$FrameRef
    )

    if ($To -lt $From) {
        $To = $From
    }

    for ($value = $From; $value -le $To; $value++) {
        Draw-ProtectedLoader -Status $Status -Percent $value -Frame $FrameRef.Value
        $FrameRef.Value++
        Start-Sleep -Milliseconds 16
    }

    return $To
}

function Get-GoldPixelWord {
    $font = @{}

    $font["G"] = @(" ### ","#    ","#  ##","#   #"," ### ")
    $font["O"] = @(" ### ","#   #","#   #","#   #"," ### ")
    $font["D"] = @("#### ","#   #","#   #","#   #","#### ")
    $font["P"] = @("#### ","#   #","#### ","#    ","#    ")
    $font["R"] = @("#### ","#   #","#### ","#  # ","#   #")
    $font["J"] = @("  ###","   # ","   # ","#  # "," ##  ")
    $font["E"] = @("#####","#    ","#### ","#    ","#####")
    $font["X"] = @("#   #"," # # ","  #  "," # # ","#   #")
    $font["T"] = @("#####","  #  ","  #  ","  #  ","  #  ")
    $font["H"] = @("#   #","#   #","#####","#   #","#   #")

    $word = "GODPROJEXTH"
    $lines = @("", "", "", "", "")

    foreach ($char in $word.ToCharArray()) {
        $glyph = $font[[string]$char]

        for ($row = 0; $row -lt 5; $row++) {
            $lines[$row] += $glyph[$row] + " "
        }
    }

    return $lines
}

function Show-GoldGodCredit {
    param([ref]$FrameRef)

    Clear-Host

    $art = Get-GoldPixelWord
    $maxLength = ($art | ForEach-Object { $_.Length } | Measure-Object -Maximum).Maximum

    Write-Host ""
    Write-Host ""
    Write-Host "  PROTECTED CREDIT" -ForegroundColor DarkYellow
    Write-Host ""

    for ($column = 1; $column -le $maxLength; $column++) {
        for ($row = 0; $row -lt $art.Count; $row++) {
            $line = $art[$row]

            if ($column -gt $line.Length) {
                $part = $line
            }
            else {
                $part = $line.Substring(0, $column)
            }

            if ($row -eq 0) {
                $color = [System.ConsoleColor]::White
            }
            elseif ($row -eq 1) {
                $color = [System.ConsoleColor]::Yellow
            }
            elseif ($row -eq 2) {
                $color = [System.ConsoleColor]::Yellow
            }
            elseif ($row -eq 3) {
                $color = [System.ConsoleColor]::DarkYellow
            }
            else {
                $color = [System.ConsoleColor]::DarkYellow
            }

            Safe-WriteLine -Top (4 + $row) -Text ("  " + $part) -Color $color
        }

        Safe-WriteLine -Top 11 -Text ("  OPENING SECURE INTERFACE  frame {0:0000}" -f $FrameRef.Value) -Color DarkYellow
        $FrameRef.Value++
        Start-Sleep -Milliseconds 24
    }

    for ($shine = 0; $shine -lt 25; $shine++) {
        for ($row = 0; $row -lt $art.Count; $row++) {
            $phase = ($shine + $row) % 5

            if ($phase -eq 0) {
                $color = [System.ConsoleColor]::White
            }
            elseif ($phase -eq 1) {
                $color = [System.ConsoleColor]::Yellow
            }
            elseif ($phase -eq 2) {
                $color = [System.ConsoleColor]::Yellow
            }
            elseif ($phase -eq 3) {
                $color = [System.ConsoleColor]::DarkYellow
            }
            else {
                $color = [System.ConsoleColor]::Yellow
            }

            Safe-WriteLine -Top (4 + $row) -Text ("  " + $art[$row]) -Color $color
        }

        Safe-WriteLine -Top 11 -Text ("  Launching GODPROJEXTH interface... frame {0:0000}" -f $FrameRef.Value) -Color DarkYellow
        $FrameRef.Value++
        Start-Sleep -Milliseconds 16
    }
}

function Write-InterfaceFile {
    param([string]$Path)

    $folder = Split-Path -Parent $Path

    if (-not (Test-Path -LiteralPath $folder)) {
        New-Item -ItemType Directory -Path $folder -Force | Out-Null
    }

    $bytes = [Convert]::FromBase64String($InterfacePayload)
    $source = [System.Text.Encoding]::UTF8.GetString($bytes)

    Set-Content -LiteralPath $Path -Value $source -Encoding UTF8 -Force
}

function Find-RuntimeCommand {
    $candidates = New-Object System.Collections.ArrayList

    $py = Get-Command "py.exe" -ErrorAction SilentlyContinue
    if ($py) {
        [void]$candidates.Add(@{ File = $py.Source; PrefixArgs = @("-3") })
    }

    $runtime = Get-Command "python.exe" -ErrorAction SilentlyContinue
    if ($runtime) {
        [void]$candidates.Add(@{ File = $runtime.Source; PrefixArgs = @() })
    }

    try {
        $localRuntime = Get-ChildItem -Path "$env:LOCALAPPDATA\Programs\Python" -Filter "python.exe" -Recurse -ErrorAction SilentlyContinue |
            Sort-Object FullName -Descending |
            Select-Object -First 1

        if ($localRuntime) {
            [void]$candidates.Add(@{ File = $localRuntime.FullName; PrefixArgs = @() })
        }
    }
    catch {
    }

    foreach ($candidate in $candidates) {
        try {
            $versionArgs = @()
            $versionArgs += $candidate.PrefixArgs
            $versionArgs += @("-c", "import sys; print(sys.version_info.major)")
            $output = & $candidate.File @versionArgs 2>$null

            if ($LASTEXITCODE -eq 0 -and ($output -join "").Trim() -eq "3") {
                return $candidate
            }
        }
        catch {
        }
    }

    return $null
}

function Test-UiEngine {
    param($Runtime)

    try {
        $args = @()
        $args += $Runtime.PrefixArgs
        $args += @("-c", "import PySide6; print('OK')")
        $output = & $Runtime.File @args 2>$null

        if ($LASTEXITCODE -eq 0 -and (($output -join "").Trim() -eq "OK")) {
            return $true
        }
    }
    catch {
    }

    return $false
}

function Install-UiEngine {
    param(
        $Runtime,
        [ref]$FrameRef
    )

    Draw-ProtectedLoader -Status "Installing smooth interface engine..." -Percent 58 -Frame $FrameRef.Value
    $FrameRef.Value++

    try {
        $upgradeArgs = @()
        $upgradeArgs += $Runtime.PrefixArgs
        $upgradeArgs += @("-m", "pip", "install", "--user", "--upgrade", "pip")
        $null = & $Runtime.File @upgradeArgs 2>$null
    }
    catch {
    }

    try {
        $installArgs = @()
        $installArgs += $Runtime.PrefixArgs
        $installArgs += @("-m", "pip", "install", "--user", "--upgrade", "PySide6")
        $null = & $Runtime.File @installArgs 2>$null

        if ($LASTEXITCODE -ne 0) {
            return $false
        }

        return $true
    }
    catch {
        return $false
    }
}

function Start-Interface {
    param($Runtime)

    $silentCandidates = New-Object System.Collections.ArrayList

    $pyw = Get-Command "pyw.exe" -ErrorAction SilentlyContinue
    if ($pyw -and $Runtime.PrefixArgs.Count -gt 0) {
        [void]$silentCandidates.Add(@{ File = $pyw.Source; Args = @("-3", "`"$InterfacePath`"") })
    }

    $runtimeW = Get-Command "pythonw.exe" -ErrorAction SilentlyContinue
    if ($runtimeW) {
        [void]$silentCandidates.Add(@{ File = $runtimeW.Source; Args = @("`"$InterfacePath`"") })
    }

    try {
        $localRuntimeW = Get-ChildItem -Path "$env:LOCALAPPDATA\Programs\Python" -Filter "pythonw.exe" -Recurse -ErrorAction SilentlyContinue |
            Sort-Object FullName -Descending |
            Select-Object -First 1

        if ($localRuntimeW) {
            [void]$silentCandidates.Add(@{ File = $localRuntimeW.FullName; Args = @("`"$InterfacePath`"") })
        }
    }
    catch {
    }

    foreach ($launcher in $silentCandidates) {
        try {
            Start-Process -FilePath $launcher.File -ArgumentList $launcher.Args -WindowStyle Hidden | Out-Null
            return $true
        }
        catch {
        }
    }

    try {
        $args = @()
        $args += $Runtime.PrefixArgs
        $args += @("`"$InterfacePath`"")
        Start-Process -FilePath $Runtime.File -ArgumentList $args -WindowStyle Hidden | Out-Null
        return $true
    }
    catch {
        throw "Cannot start GODPROJEXTH interface."
    }
}

try {
    Initialize-Loader

    $frame = 0
    $progress = 0

    $progress = Animate-ToPercent -From $progress -To 16 -Status "Starting protected loader..." -FrameRef ([ref]$frame)
    $progress = Animate-ToPercent -From $progress -To 32 -Status "Decrypting embedded interface payload..." -FrameRef ([ref]$frame)
    $progress = Animate-ToPercent -From $progress -To 44 -Status "Preparing protected interface..." -FrameRef ([ref]$frame)

    New-Item -ItemType Directory -Path $InstallDir -Force | Out-Null
    Write-InterfaceFile -Path $InterfacePath

    $progress = Animate-ToPercent -From $progress -To 54 -Status "Finding desktop runtime..." -FrameRef ([ref]$frame)

    $runtime = Find-RuntimeCommand

    if ($null -eq $runtime) {
        throw "Required desktop runtime not found."
    }

    if (-not (Test-UiEngine -Runtime $runtime)) {
        [void](Install-UiEngine -Runtime $runtime -FrameRef ([ref]$frame))
    }

    if (Test-UiEngine -Runtime $runtime) {
        $progress = Animate-ToPercent -From 72 -To 86 -Status "Smooth interface engine ready..." -FrameRef ([ref]$frame)
    }
    else {
        $progress = Animate-ToPercent -From 72 -To 86 -Status "Compatibility interface enabled..." -FrameRef ([ref]$frame)
    }

    $progress = Animate-ToPercent -From $progress -To 100 -Status "Opening GODPROJEXTH interface..." -FrameRef ([ref]$frame)

    Show-GoldGodCredit -FrameRef ([ref]$frame)

    Start-Interface -Runtime $runtime | Out-Null

    Start-Sleep -Milliseconds 900

    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    exit 0
}
catch {
    try {
        [Console]::CursorVisible = $true
    }
    catch {
    }

    try {
        Add-Content -Path $ErrorLog -Value $_.Exception.Message -Encoding UTF8
    }
    catch {
    }

    Show-ConsoleWindow

    Clear-Host
    Write-Host ""
    Write-Host "  GODPROJEXTH ALPHA ERROR" -ForegroundColor Red
    Write-Host ""
    Write-Host "  $($_.Exception.Message)" -ForegroundColor Red
    Write-Host ""
    Write-Host "  Error log:" -ForegroundColor Yellow
    Write-Host "  $ErrorLog" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "  Press Enter to close..." -ForegroundColor Yellow
    [void][System.Console]::ReadLine()
}
